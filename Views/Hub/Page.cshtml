@model AnnouncmentHub.Models.Page
@using AnnouncmentHub.Models

@{
    ViewData["Title"] = Model.PageTitle;
    var relatedPages = ViewBag.RelatedPages as List<Page>;
}

@section Styles {
    <style>
        .page-view {
            background: #f0ede4;
            min-height: 100vh;
        }

        /* ── Hero ── */
        .page-hero {
            background: linear-gradient(160deg,#eae7de 0%,#f0ede4 60%,#e4e1d8 100%);
            position: relative;
            overflow: hidden;
            padding: 40px 0 48px;
        }

            .page-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(circle at 75% 50%, rgba(13,148,136,.07) 0%, transparent 55%), radial-gradient(circle at 10% 80%, rgba(245,158,11,.05) 0%, transparent 50%);
            }

        /* ── Content prose ── */
        .page-prose {
            font-size: 15px;
            line-height: 2;
            color: #3a3a3a;
            text-align: right;
            direction: rtl;
        }

            .page-prose p {
                margin-bottom: 16px;
            }

            .page-prose h2 {
                font-size: 20px;
                font-weight: 900;
                color: #0d2b28;
                margin: 32px 0 12px;
            }

            .page-prose h3 {
                font-size: 17px;
                font-weight: 900;
                color: #0d2b28;
                margin: 24px 0 10px;
            }

            .page-prose ul, .page-prose ol {
                padding-right: 20px;
                margin-bottom: 16px;
            }

            .page-prose li {
                margin-bottom: 8px;
            }

            .page-prose a {
                color: #0d9488;
                text-decoration: underline;
            }

                .page-prose a:hover {
                    color: #0f766e;
                }

            .page-prose strong {
                font-weight: 900;
                color: #1a1a1a;
            }

            .page-prose blockquote {
                border-right: 3px solid #0d9488;
                padding: 12px 18px;
                background: #e6f4f2;
                border-radius: 0 12px 12px 0;
                margin: 20px 0;
                color: #0f4a44;
                font-style: normal;
                font-weight: 700;
            }

        /* ── Sidebar related link ── */
        .related-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 800;
            color: #555;
            border: 1px solid transparent;
            transition: all .2s ease;
        }

            .related-link:hover {
                background: #e6f4f2;
                color: #0d9488;
                border-color: rgba(13,148,136,.2);
                transform: translateX(-3px);
            }

            .related-link.active {
                background: linear-gradient(135deg,#0d9488,#0f766e);
                color: #fff;
                border-color: transparent;
                box-shadow: 0 4px 12px rgba(13,148,136,.3);
            }

        /* ── Scroll reveal ── */
        .sr {
            opacity: 0;
            transform: translateY(16px);
            transition: opacity .45s ease, transform .45s ease;
        }

            .sr.visible {
                opacity: 1;
                transform: translateY(0);
            }
    </style>
}

<div class="page-view" dir="rtl">

    @* ── Hero ── *@
    <div class="page-hero">
        <div class="max-w-7xl mx-auto px-4 md:px-8 relative">
            <span class="text-secondary font-bold text-xs tracking-[.2em] uppercase mb-2 block">
                @(Model.pageCategory?.CatName ?? "صفحات")
            </span>
            <h1 class="text-3xl md:text-4xl font-black font-headline tracking-tighter text-on-surface leading-tight">
                @Model.PageTitle
            </h1>
        </div>
    </div>

    @* ── Body ── *@
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-10 flex flex-col lg:flex-row gap-8 items-start">

        @* ── Main content ── *@
        <article class="flex-1 min-w-0 space-y-6">

            @* Content card *@
            <div class="bg-[#f7f4ee] border border-[#e0ddd4] rounded-2xl p-6 md:p-10 sr">
                <div class="page-prose">
                    @Html.Raw(Model.PageDetails)
                </div>
            </div>

            @* Back + date row *@
            <div class="flex items-center justify-between sr">
                <a href="javascript:history.back()"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#f7f4ee] border border-[#e0ddd4] rounded-xl text-xs font-black text-on-surface-variant hover:border-secondary hover:text-secondary transition-all duration-200">
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    العودة
                </a>
                <span class="inline-flex items-center gap-1.5 text-[10px] font-black text-outline uppercase tracking-widest">
                    <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                    آخر تحديث: @DateTime.Now.ToString("dd/MM/yyyy")
                </span>
            </div>
        </article>

        @* ── Sidebar ── *@
        @if (relatedPages != null && relatedPages.Any())
        {
            <aside class="w-full lg:w-60 flex-shrink-0 lg:sticky lg:top-24 sr">
                <div class="bg-[#f7f4ee] border border-[#e0ddd4] rounded-2xl overflow-hidden">
                    <div class="px-4 py-3 border-b border-[#e8e4d8] flex items-center gap-2">
                        <i data-lucide="files" class="w-3.5 h-3.5 text-secondary"></i>
                        <span class="text-[10px] font-black text-outline uppercase tracking-widest">صفحات ذات صلة</span>
                    </div>
                    <div class="p-2 flex flex-col gap-0.5">
                        @foreach (var p in relatedPages)
                        {
                            bool isCurrent = p.Id == Model.Id;
                            <a href="/Hub/Page/@p.Id"
                               class="related-link @(isCurrent ? "active" : "")">
                                <i data-lucide="@(isCurrent ? "circle-dot" : "chevron-left")" class="w-3.5 h-3.5 flex-shrink-0"></i>
                                <span class="leading-snug">@p.PageTitle</span>
                            </a>
                        }
                    </div>
                </div>
            </aside>
        }

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, i) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => entry.target.classList.add('visible'), i * 80);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.06 });
            document.querySelectorAll('.sr').forEach(el => observer.observe(el));
            lucide.createIcons();
        });
    </script>
}
