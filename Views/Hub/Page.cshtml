@model AnnouncmentHub.Models.Page
@using AnnouncmentHub.Models

@{
    ViewData["Title"] = Model.PageTitle;
    var relatedPages = ViewBag.RelatedPages as List<Page>;
}

@* ── Hero Header ── *@
<div class="page-hero">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-10">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item">
                            <a href="/" class="text-white-50 text-decoration-none">🏠 الرئيسية</a>
                        </li>
                        <li class="breadcrumb-item text-white-50">
                            @Model.pageCategory?.CatName
                        </li>
                        <li class="breadcrumb-item text-white active" aria-current="page">
                            @Model.PageTitle
                        </li>
                    </ol>
                </nav>
                <h1 class="display-5 fw-bold text-white mb-0">@Model.PageTitle</h1>
            </div>
        </div>
    </div>
</div>

@* ── المحتوى ── *@
<div class="container py-5">
    <div class="row justify-content-center g-4">

        @* ── المحتوى الرئيسي ── *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-lg-5">
                    <div class="page-content">
                        @Html.Raw(Model.PageDetails)
                    </div>
                    <hr class="my-4 opacity-25" />
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-right me-2"></i> رجوع
                        </a>
                        <span class="text-muted small">
                            <i class="fas fa-clock me-1"></i>
                            آخر تحديث: @DateTime.Now.ToString("dd/MM/yyyy")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* ── الـ Sidebar ── *@
        @if (relatedPages != null && relatedPages.Any())
        {
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 sticky-sidebar">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3 sidebar-title">
                            <i class="fas fa-layer-group me-2"></i> صفحات ذات صلة
                        </h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var p in relatedPages)
                            {
                                <li class="mb-1">
                                    <a href="/Hub/Page/@(p.Id)" class="sidebar-link">
                                        <i class="fas fa-chevron-left ms-1"></i>
                                        @p.PageTitle
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<style>
    .page-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        padding: 60px 0 40px;
        position: relative;
        overflow: hidden;
    }

        .page-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 60%);
            pointer-events: none;
        }

    .page-content {
        font-size: 1.05rem;
        line-height: 2;
        color: #444;
    }

        .page-content p {
            margin-bottom: 1.2rem;
        }

        .page-content h2,
        .page-content h3 {
            font-weight: 700;
            margin-top: 2rem;
            color: #1a1a2e;
        }

    .sticky-sidebar {
        position: sticky;
        top: 80px;
    }

    .sidebar-title {
        color: #1a1a2e;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 10px;
    }

    .sidebar-link {
        display: block;
        padding: 8px 12px;
        border-radius: 8px;
        color: #555;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

        .sidebar-link:hover {
            background: #f0f4ff;
            color: #0f3460;
            padding-right: 16px;
        }
</style>
