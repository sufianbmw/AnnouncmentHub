@using AnnouncmentHub.Models
@{
    var parentCategories = ViewBag.ParentCategories as List<Category>;
    ViewData["Title"] = "تصفّح بالتصنيف";
}

@* ═══════════════════════ PDF MODAL (unchanged) ═══════════════════════ *@
<div id="pdfModal" class="modal">
    <div class="modal-content">
        <span id="closePdfModal" class="close">&times;</span>
        <iframe id="pdfViewerFrame" src="" width="100%" height="800px" style="border:none;"></iframe>
        <div id="pdfShareButtons" class="pdf-share mt-2" style="display:flex; gap:10px; justify-content:center;">
            <a id="pdf-share-facebook" target="_blank" rel="noopener noreferrer" title="مشاركة على فيسبوك" class="social-btn fb"><i class="fab fa-facebook-f"></i></a>
            <a id="pdf-share-twitter" target="_blank" rel="noopener noreferrer" title="مشاركة على تويتر" class="social-btn tw"><i class="fab fa-twitter"></i></a>
            <a id="pdf-share-whatsapp" target="_blank" rel="noopener noreferrer" title="مشاركة على واتساب" class="social-btn wa"><i class="fab fa-whatsapp"></i></a>
            <a id="pdf-share-download" target="_blank" rel="noopener noreferrer" title="تحميل" class="social-btn Dow"><i class="fa-solid fa-download"></i></a>
        </div>
    </div>
</div>

@* ═══════════════════════ IMAGE SHARE BUTTONS (unchanged) ═══════════════════════ *@
<div id="imageShareButtons" class="pdf-share" style="display:none;">
    <a id="image-share-facebook" target="_blank" rel="noopener noreferrer" title="مشاركة على فيسبوك" class="social-btn fb"><i class="fab fa-facebook-f"></i></a>
    <a id="image-share-twitter" target="_blank" rel="noopener noreferrer" title="مشاركة على تويتر" class="social-btn tw"><i class="fab fa-twitter"></i></a>
    <a id="image-share-whatsapp" target="_blank" rel="noopener noreferrer" title="مشاركة على واتساب" class="social-btn wa"><i class="fab fa-whatsapp"></i></a>
    <a id="image-share-download" target="_blank" rel="noopener noreferrer" title="تحميل" class="social-btn Dow"><i class="fa-solid fa-download"></i></a>
</div>

@* ═══════════════════════ PAGE HEADER ═══════════════════════ *@
<div class="bg-[#f0ede4] pt-8 pb-6 px-4 md:px-8 border-b border-outline-variant/40">
    <div class="max-w-7xl mx-auto">
        <span class="text-secondary font-bold text-sm tracking-[0.2em] uppercase mb-2 block">استكشف الإعلانات</span>
        <h1 class="text-3xl md:text-4xl font-black font-headline tracking-tighter">تصفّح بالتصنيف</h1>
    </div>
</div>

@* ═══════════════════════ CATEGORY BROWSER ═══════════════════════ *@
<div class="max-w-7xl mx-auto px-4 md:px-8 py-8">

    @* Parent category buttons *@
    <div class="bg-[#f7f4ee] rounded-2xl p-5 md:p-7 mb-6 shadow-sm border border-outline-variant/30">

        <p class="text-xs font-black text-outline uppercase tracking-widest mb-4">اختر تصنيفاً رئيسياً</p>

        <div class="flex flex-wrap gap-3" id="parentCategoryList">
            @if (parentCategories != null)
            {
                @foreach (var category in parentCategories)
                {
                    <button class="category-btn px-5 py-2.5 rounded-xl text-sm font-black border-2 border-transparent
                                           bg-[#e8e4d8] text-on-surface-variant
                                           hover:bg-secondary hover:text-white hover:border-secondary
                                           active:scale-95 transition-all duration-200"
                            data-category-id="@category.Id">
                        @category.CatName
                    </button>
                }
            }
        </div>

        @* Subcategory strip — populated by JS *@
        <div id="subcategories-container" class="mt-5 pt-5 border-t border-outline-variant/40 hidden">
            <p class="text-xs font-black text-outline uppercase tracking-widest mb-3">اختر تصنيفاً فرعياً</p>
            <div id="subcategories-list-inner" class="flex flex-wrap gap-2"></div>
        </div>
    </div>

    @* Announcement results area *@
    <div id="announcementArea">
        <div id="announcementList">

            @* Default empty state *@
            <div id="emptyState" class="text-center py-20 text-on-surface-variant">
                <i data-lucide="layout-grid" class="w-14 h-14 mx-auto mb-4 opacity-25"></i>
                <p class="font-black text-base mb-1">اختر تصنيفاً للبدء</p>
                <p class="text-sm">اضغط على أحد التصنيفات الرئيسية أعلاه</p>
            </div>

        </div>
    </div>

</div>

@* PhotoSwipe gallery root (unchanged) *@
<div class="pswp-gallery" id="imageGallery"></div>
<div class="pswp" tabindex="-1" role="dialog" aria-hidden="true"></div>

@section Scripts {
    <script src="~/js/photoswipe/photoswipe.umd.min.js"></script>
    <script src="~/js/photoswipe/photoswipe-lightbox.umd.min.js"></script>
    <link href="~/css/landing.css" rel="stylesheet" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ═══════════════════════════════════════════════
            // ALL JS LOGIC BELOW IS UNCHANGED FROM ORIGINAL
            // ═══════════════════════════════════════════════

            // 🔗 Share helper
            function updateShareLinks(prefix, url) {
                const full = url.startsWith('http') ? url : window.location.origin + url;
                const enc = encodeURIComponent(full);
                const fb = document.getElementById(`${prefix}-facebook`);
                const tw = document.getElementById(`${prefix}-twitter`);
                const wa = document.getElementById(`${prefix}-whatsapp`);
                const dw = document.getElementById(`${prefix}-download`);
                if (fb && tw && wa && dw) {
                    fb.href = `https://www.facebook.com/sharer/sharer.php?u=${enc}`;
                    tw.href = `https://twitter.com/intent/tweet?url=${enc}`;
                    wa.href = `https://wa.me/?text=${enc}`;
                    dw.href = full;
                }
            }

            // ✅ PDF viewer
            function openPdfViewer(filePath) {
                const fullUrl = window.location.origin + `/Scripts/pdfjs/web/viewer.html?file=${filePath}`;
                document.getElementById('pdfViewerFrame').src = fullUrl;
                const fileFullUrl = window.location.origin + filePath;
                updateShareLinks('pdf-share', fileFullUrl);
                document.getElementById('pdfModal').style.display = 'flex';
            }

            // Close modal
            document.getElementById("closePdfModal").onclick = function () {
                document.getElementById('pdfModal').style.display = "none";
                document.getElementById('pdfViewerFrame').src = "";
            };
            window.onclick = function (e) {
                const modal = document.getElementById('pdfModal');
                if (e.target === modal) {
                    modal.style.display = "none";
                    document.getElementById('pdfViewerFrame').src = "";
                }
            };

            // Load subcategories
            window.loadSubcategories = function (parentId) {
                fetch(`/Hub/GetSubcategories?parentId=${parentId}`)
                    .then(res => res.json())
                    .then(data => {
                        const wrapper = document.getElementById('subcategories-container');
                        const inner   = document.getElementById('subcategories-list-inner');
                        inner.innerHTML = '';

                        if (data.length === 0) {
                            inner.innerHTML = '<p class="text-sm text-on-surface-variant">لا توجد تصنيفات فرعية حالياً</p>';
                            wrapper.classList.remove('hidden');
                            return;
                        }

                        data.forEach(sub => {
                            const btn = document.createElement('button');
                            btn.className = 'subcategory-btn px-4 py-2 rounded-xl text-xs font-black border-2 border-transparent bg-[#e8e4d8] text-on-surface-variant hover:bg-secondary hover:text-white transition-all duration-200';
                            btn.setAttribute('data-subcategory-id', sub.id);
                            btn.textContent = sub.catName;
                            inner.appendChild(btn);
                        });

                        wrapper.classList.remove('hidden');

                        inner.querySelectorAll('.subcategory-btn').forEach(btn => {
                            btn.addEventListener('click', () => {
                                inner.querySelectorAll('.subcategory-btn').forEach(b => b.classList.remove('active', 'bg-secondary', 'text-white'));
                                btn.classList.add('active', 'bg-secondary', 'text-white');
                                loadAnnouncementsBySubcategory(btn.dataset.subcategoryId);
                            });
                        });
                    });
            };

            // Load announcements — new card HTML, same fetch logic
            function loadAnnouncementsBySubcategory(id) {
                const list = document.getElementById('announcementList');
                list.innerHTML = `
                    <div class="text-center py-12 text-on-surface-variant">
                        <div class="w-8 h-8 border-2 border-secondary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
                        <p class="text-sm font-bold">جاري التحميل...</p>
                    </div>`;

                fetch(`/Hub/GetAnnouncementsBySubcategory?subCategoryId=${id}`)
                    .then(res => res.json())
                    .then(data => {
                        list.innerHTML = '';

                        if (!data.length) {
                            list.innerHTML = `
                                <div class="text-center py-16 text-on-surface-variant">
                                    <p class="font-bold text-sm">لا توجد إعلانات في هذا التصنيف حالياً</p>
                                </div>`;
                            return;
                        }

                        const grid = document.createElement('div');
                        grid.className = 'grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-5';

                        data.forEach(item => {
                            const card = document.createElement('div');
                            card.className = 'listing-card group cursor-pointer';
                            card.innerHTML = `
                                <div class="listing-img-wrap relative aspect-[4/3] mb-3">
                                    <a href="/Hub/Details/${item.id}">
                                        <img src="${item.thumbnailPath}"
                                             class="listing-img w-full h-full object-cover"
                                             alt="${item.title}"
                                             loading="lazy"
                                             onerror="this.onerror=null;this.src='/images/file-icons/no-image.jpg';" />
                                    </a>
                                    <button class="viewFileBtn wishlist-btn absolute top-3 left-3 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-sm"
                                            data-file-path="${item.filePath}">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                </div>
                                <div class="px-1">
                                    <a href="/Hub/Details/${item.id}"
                                       class="block font-black text-sm text-on-surface leading-tight hover:text-secondary transition-colors line-clamp-2 mb-2">
                                        ${item.title}
                                    </a>
                                    <span class="text-[10px] font-black text-secondary flex items-center gap-1">
                                        عرض التفاصيل →
                                    </span>
                                </div>`;
                            grid.appendChild(card);
                        });

                        list.appendChild(grid);
                        lucide.createIcons(); // re-init any lucide icons

                        // Attach file viewer to view buttons
                        list.querySelectorAll('.viewFileBtn').forEach(button => {
                            button.addEventListener('click', e => {
                                e.preventDefault();
                                const path = button.getAttribute('data-file-path');
                                if (!path) return;
                                const ext = path.split('.').pop().toLowerCase();
                                const isImage = ['jpg','jpeg','png','gif','bmp','webp'].includes(ext);
                                if (isImage) {
                                    openImageViewer([{ url: path }]);
                                } else {
                                    openPdfViewer(path);
                                }
                            });
                        });
                    });
            }

            // Image size helper
            async function getImageSize(url) {
                return new Promise(res => {
                    const img = new Image();
                    img.onload  = () => res({ width: img.naturalWidth,  height: img.naturalHeight });
                    img.onerror = () => res({ width: 800, height: 600 });
                    img.src = url;
                });
            }

            // Image viewer (PhotoSwipe — unchanged)
            async function openImageViewer(imageList) {
                const galleryEl = document.getElementById('imageGallery');
                galleryEl.innerHTML = '';
                for (const img of imageList) {
                    if (!img.url) continue;
                    const size   = await getImageSize(img.url);
                    const anchor = document.createElement('a');
                    anchor.href = img.url;
                    anchor.setAttribute('data-pswp-width',  size.width);
                    anchor.setAttribute('data-pswp-height', size.height);
                    anchor.setAttribute('data-caption',     img.caption || '');
                    anchor.innerHTML = `<img src="${img.url}" style="display:none" />`;
                    galleryEl.appendChild(anchor);
                }
                const lightbox = new PhotoSwipeLightbox({
                    gallery: '#imageGallery',
                    children: 'a',
                    pswpModule: PhotoSwipe,
                    captionAttribute: 'data-caption'
                });
                lightbox.on('change', () => {
                    const current = lightbox.pswp.currSlide;
                    if (!current?.data?.src) return;
                    const shareBar = document.getElementById('imageShareButtons');
                    if (shareBar) {
                        shareBar.style.display = 'inline-flex';
                        updateShareLinks('image-share', current.data.src);
                    }
                });
                lightbox.on('close', () => {
                    const shareBar = document.getElementById('imageShareButtons');
                    if (shareBar) shareBar.style.display = 'none';
                });
                lightbox.init();
                galleryEl.querySelector('a')?.click();
            }

            // Hook parent category buttons
            document.querySelectorAll('.category-btn').forEach(button => {
                button.addEventListener('click', () => {
                    document.querySelectorAll('.category-btn').forEach(b => {
                        b.classList.remove('active', 'bg-secondary', 'text-white', 'border-secondary');
                        b.classList.add('bg-[#e8e4d8]', 'text-on-surface-variant');
                    });
                    button.classList.add('active', 'bg-secondary', 'text-white', 'border-secondary');
                    button.classList.remove('bg-[#e8e4d8]', 'text-on-surface-variant');

                    // Hide empty state
                    const empty = document.getElementById('emptyState');
                    if (empty) empty.style.display = 'none';

                    window.loadSubcategories(button.getAttribute('data-category-id'));
                });
            });

        });
    </script>
}
