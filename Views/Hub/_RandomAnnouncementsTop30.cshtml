@using AnnouncmentHub.Helpers
@model AnnouncmentHub.ViewModels.AnnouncementSearchResult

@* ✅ Local function: image logic unchanged *@
@{
    string GetDisplayPath(string filePath, List<AnnouncmentHub.Helpers.AnnouncementImageVm> images)
    {
        var extension = System.IO.Path.GetExtension(filePath ?? "").ToLower();
        var imageExts = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp" };

        if (!string.IsNullOrEmpty(filePath) && imageExts.Contains(extension))
            return filePath;

        var firstDbImage = images?.FirstOrDefault()?.ImageUrl;
        if (!string.IsNullOrEmpty(firstDbImage))
        {
            firstDbImage = firstDbImage.Replace("\\", "/");
            if (!firstDbImage.StartsWith("/"))
                firstDbImage = "/" + firstDbImage;
            return firstDbImage;
        }

        if (string.IsNullOrEmpty(filePath)) return "/images/file-icons/no-image.jpg";
        if (extension == ".pdf") return "/images/file-icons/pdf-icon.png";
        if (extension == ".doc" || extension == ".docx") return "/images/file-icons/word-icon.png";
        if (extension == ".xls" || extension == ".xlsx") return "/images/file-icons/excel-icon.png";
        return "/images/file-icons/file-icon.png";
    }
}

@if (Model?.Announcements != null && Model.Announcements.Any())
{
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        @foreach (var item in Model.Announcements)
        {
            var displayPath = GetDisplayPath(item.FilePath, item.Images);

            <div class="listing-card group cursor-pointer">

                @* Image wrap *@
                <div class="listing-img-wrap relative aspect-[4/3] mb-3">
                    <a asp-controller="Hub" asp-action="Details" asp-route-id="@item.Id">
                        <img src="@displayPath"
                             alt="@item.Title"
                             title="@item.Title"
                             loading="lazy"
                             class="listing-img w-full h-full object-cover"
                             onerror="this.onerror=null;this.src='/images/file-icons/no-image.jpg';" />
                    </a>

                    @* Category badge *@
                    @if (item.Categories != null && item.Categories.Any())
                    {
                        var firstCat = item.Categories.First();
                        <div class="badge absolute top-3 right-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm rounded-full text-[10px] font-black text-secondary shadow-sm">
                            <a asp-controller="Hub"
                               asp-action="SubCategoryAnnouncements"
                               asp-route-id="@firstCat.CategoryId"
                               class="text-secondary">
                                @firstCat.CategoryName
                            </a>
                        </div>
                    }

                    @* Wishlist button *@
                    <button class="wishlist-btn absolute top-3 left-3 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-sm">
                        <i data-lucide="heart" class="w-4 h-4 text-outline"></i>
                    </button>

                    @* File button if has file *@
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <a href="@item.FilePath" target="_blank"
                           class="absolute bottom-3 left-3 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-sm">
                            <i data-lucide="file" class="w-4 h-4 text-outline"></i>
                        </a>
                    }
                </div>

                @* Card info *@
                <div class="px-1">
                    <a asp-controller="Hub" asp-action="Details" asp-route-id="@item.Id"
                       class="block font-black text-sm text-on-surface leading-tight mb-1 hover:text-secondary transition-colors line-clamp-2">
                        @item.Title
                    </a>

                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <p class="text-[11px] text-on-surface-variant leading-relaxed mb-2 line-clamp-2">
                            @(item.Description.Length > 70
                                            ? item.Description.Substring(0, 70) + "..."
                                            : item.Description)
            </p>
                        }

                    <div class="flex items-center justify-between mt-2">
                        @if (item.AddedDate.HasValue)
                        {
                            <span class="text-[10px] font-bold text-outline flex items-center gap-1">
                                <i data-lucide="clock" class="w-3 h-3"></i>
                                @DateTimeHelper.FormatDateTime(item.AddedDate)
                            </span>
                        }
                        <a asp-controller="Hub" asp-action="Details" asp-route-id="@item.Id"
                           class="text-[10px] font-black text-secondary flex items-center gap-1 hover:gap-2 transition-all">
                            عرض <i data-lucide="chevron-left" class="w-3 h-3"></i>
                        </a>
                    </div>
                </div>

            </div>
        }
    </div>
}
else
{
    <div class="text-center py-16 text-on-surface-variant">
        <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 opacity-30"></i>
        <p class="font-bold text-sm">لا توجد إعلانات حالياً</p>
    </div>
}
