@using AnnouncmentHub.Helpers
@model CategoryAnnouncementsViewModel

<div class="row g-3">
    @if (Model?.Announcements != null && Model.Announcements.Any())
    {
        @foreach (var item in Model.Announcements)
        {
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card shadow-sm h-100 announcement-card">

                    <div class="row g-0 h-100">
                        <!-- Thumbnail -->
                        <d class="col-4 bg-light d-flex align-items-center justify-content-center">
                            @{
                                var filePath = item.FilePath;
                                var extension = System.IO.Path.GetExtension(filePath ?? "").ToLower();
                                string displayPath = extension switch
                                {
                                    ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" => filePath,
                                    ".pdf" => Url.Content("~/images/file-icons/pdf-icon.png"),
                                    ".doc" or ".docx" => Url.Content("~/images/file-icons/word-icon.png"),
                                    ".xls" or ".xlsx" => Url.Content("~/images/file-icons/excel-icon.png"),
                                    _ when string.IsNullOrEmpty(filePath) => Url.Content("~/images/file-icons/no-image.jpg"),
                                    _ => Url.Content("~/images/file-icons/file-icon.png")
                                };
                            }
                            <div class="ratio ratio-1x1 bg-white border rounded overflow-hidden m-2">
                                <img src="@displayPath"
                                     class="w-100 h-100 object-fit-cover"
                                     alt="Thumbnail" />
                            </div>
                        </d xcvb\]" iv>

                        <!-- Content -->
                        <div class="col-8">
                            <div class="card-body p-2 d-flex flex-column h-100">
                                <h6 class="fw-bold mb-1 text-truncate">
                                    <a asp-controller="Hub"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="text-decoration-none text-dark">
                                        @item.Title
                                    </a>
                                </h6>

                                <p class="text-muted small mb-2">
                                    @Html.Raw(HtmlTruncator.TruncateHtml(item.Description, 60))
                                </p>

                                <span class="text-muted small mt-auto">
                                    🗓️ @item.AddedDate?.ToString("yyyy-MM-dd")
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center shadow-sm">
                لا توجد إعلانات مطابقة للفلتر.
            </div>
        </div>
    }
</div>
