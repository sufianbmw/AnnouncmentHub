@model Search2ViewModel

@{
    ViewBag.Title = "بحث الإعلانات";
}

<div class="container-fluid">
    <div class="row">

        <!-- 🟦 Sidebar (Main Categories) -->
        <div class="col-md-2 bg-light border-end pt-3">

            <h6 class="fw-bold mb-3">التصنيفات الرئيسية</h6>

            @if (Model.MainCategories != null && Model.MainCategories.Any())
            {
                @foreach (var mc in Model.MainCategories)
                {
                    <a class="btn bgGradiantSrch bgGradiants w-100 text-start mb-2 @(Model.MainCategoryId == mc.Id ? "active" : "")"
                       asp-action="Search2"
                       asp-route-mainCategoryId="@mc.Id">
                        @mc.CatName
                    </a>
                }
            }
            else
            {
                <div class="text-muted small">لا توجد تصنيفات رئيسية.</div>
            }

        </div>

        <!-- 🟩 Main Content -->
        <div class="col-md-10 p-4">

            <!-- 🔎 Filters (Title + Date) -->
            <form id="searchFilters" onsubmit="event.preventDefault(); triggerFilter(1);">
                <input type="hidden" id="mainCategoryId" value="@(Model.MainCategoryId ?? 0)" />
                <input type="hidden" id="pageSize" value="@Model.PageSize" />

                <div class="row g-3 bgGradiants border rounded p-3">

                    <div class="col-md-4">
                        <label class="form-label">كلمة البحث</label>
                        <input type="text" id="filter-title" class="form-control" value="@Model.Title" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">من تاريخ</label>
                        <input type="date" id="filter-dateFrom"
                               class="form-control"
                               value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">إلى تاريخ</label>
                        <input type="date" id="filter-dateTo"
                               class="form-control"
                               value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                    </div>  
                  
                    <!-- ⭐ Subcategories as Badges -->
                    @if (Model.SubCategories != null && Model.SubCategories.Any())
                    {
                        <div class="mt-3 shadow-sm p-3 rounded border">
                            <h6 class="fw-bold text-secondary mb-2">فلتر حسب الفئات الفرعية</h6>

                            <div class="filter-badges">

                                <!-- عرض الكل -->
                                <span class="filter-badge @(Model.SubCategoryIds == null || !Model.SubCategoryIds.Any() ? "active" : "")"
                                      data-id="0">
                                    عرض الكل
                                </span>

                                @foreach (var sc in Model.SubCategories)
                                {
                                    var isActive = Model.SubCategoryIds != null && Model.SubCategoryIds.Contains(sc.Id);
                                    <span class="filter-badge @(isActive ? "active" : "")"
                                          data-id="@sc.Id">
                                        @sc.CatName
                                    </span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="mt-3 d-flex justify-content-center gap-2">
                        <button type="submit" class="btn btn-primary">بحث</button>
                        <button type="button" class="btn btn-secondary" onclick="resetSearch()">إعادة تعيين</button>
                    </div>
                </div>

             
            </form>

            <!-- 🔹 Announcements container (AJAX updates here) -->
            <div id="announcements-container" class="mt-4">
                @await Html.PartialAsync("_Search2AnnouncementsPartial", Model)
            </div>

            <!-- 🔹 Pagination container -->
            <div id="pagination-container" class="mt-2">
                @await Html.PartialAsync("_Search2PaginationPartial", Model)
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>
        // 🔁 Reset filters and reload page (no filters)
        function resetSearch() {
            // رجوع للـ GET بدون باراميتر
            window.location = '@Url.Action("Search2", "Hub")';
        }

        // 🟣 Badge click logic (subcategories)
        $(document).on("click", ".filter-badge", function () {

            const id = parseInt($(this).data("id"));

            if (id === 0) {
                // "عرض الكل"
                $(".filter-badge").removeClass("active");
                $(this).addClass("active");
            } else {
                // أي فرع آخر
                $(".filter-badge[data-id=0]").removeClass("active");
                $(this).toggleClass("active");

                // إذا ولا واحد مفعّل → رجّع "عرض الكل"
                if ($(".filter-badge.active").length === 0) {
                    $(".filter-badge[data-id=0]").addClass("active");
                }
            }

            // ممكن تخليها بدون بحث تلقائي وتخلي فقط الزر،
            // لكن بما اخترنا AJAX، نخليه يفلتر مباشرة:
            triggerFilter(1);
        });


        // 🧠 تجميع الفلاتر الحالية
        function collectFilters(page) {

            const mainCategoryId = parseInt($("#mainCategoryId").val()) || null;
            const pageSize = parseInt($("#pageSize").val()) || 10;
            const title = $("#filter-title").val();
            const dateFrom = $("#filter-dateFrom").val();
            const dateTo = $("#filter-dateTo").val();

            // IDs للفئات الفرعية النشطة
            let subIds = [];
            $(".filter-badge.active").each(function () {
                const id = parseInt($(this).data("id"));
                if (id !== 0) { // 0 = عرض الكل
                    subIds.push(id);
                }
            });

            return {
                mainCategoryId: mainCategoryId,
                subCategoryIds: subIds,
                title: title,
                dateFrom: dateFrom || null,
                dateTo: dateTo || null,
                page: page,
                pageSize: pageSize
            };
        }

        // 🔥 Main AJAX Filter Function
        function triggerFilter(page) {

            const filters = collectFilters(page);

            $.ajax({
                type: "POST",
                url: '@Url.Action("Search2Ajax", "Hub")',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(filters),
                beforeSend: function () {
                    // ممكن تحط لودر بسيط هنا لو حاب
                },
                success: function (data) {
                    $("#announcements-container").html(data.announcements);
                    $("#pagination-container").html(data.pagination);
                },
                error: function (xhr, status, error) {
                    console.error("❌ Search2Ajax error:", error);
                }
            });
        }

        // 📄 Pagination handler (called from pagination partial)
        function loadPage(page) {
            triggerFilter(page);
        }
    </script>

    <style>
        .filter-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .filter-badge {
            padding: 6px 14px;
            background: #f1f1f1;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
            border: 1px solid #ddd;
            transition: 0.2s;
            user-select: none;
        }

            .filter-badge:hover {
                background: #e5e5e5;
            }

            .filter-badge.active {
                background: #0d6efd;
                color: #fff;
                border-color: #0d6efd;
            }
    </style>

}
