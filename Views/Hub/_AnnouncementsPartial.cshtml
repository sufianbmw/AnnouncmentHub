@using AnnouncmentHub.Helpers
@model AnnouncmentHub.ViewModels.AnnouncementSearchResult

@{
    string GetDisplayPath(string filePath, List<AnnouncmentHub.Helpers.AnnouncementImageVm> images)
    {
        var imageExts = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp" };
        var ext = System.IO.Path.GetExtension(filePath ?? "").ToLower();

        if (!string.IsNullOrEmpty(filePath) && imageExts.Contains(ext)) return filePath;

        var first = images?.FirstOrDefault()?.ImageUrl;
        if (!string.IsNullOrEmpty(first))
        {
            first = first.Replace("\\", "/");
            if (!first.StartsWith("/")) first = "/" + first;
            return first;
        }

        if (string.IsNullOrEmpty(filePath)) return "/images/file-icons/no-image.jpg";
        if (ext == ".pdf") return "/images/file-icons/pdf-icon.png";
        if (ext == ".doc" || ext == ".docx") return "/images/file-icons/word-icon.png";
        if (ext == ".xls" || ext == ".xlsx") return "/images/file-icons/excel-icon.png";
        return "/images/file-icons/file-icon.png";
    }
}

@if (Model.Announcements != null && Model.Announcements.Any())
{
    <div class="announcements-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-6">
        @foreach (var item in Model.Announcements)
        {
            var img = GetDisplayPath(item.FilePath, item.Images);
            var isVip = item.IsVIP;

            <div class="listing-card group cursor-pointer text-right ann-card-enter">

                @* Image *@
                <a href="/Hub/Details/@item.Id" class="listing-img-wrap block aspect-[4/5] mb-4 relative">
                    <img src="@img"
                         class="listing-img w-full h-full object-cover"
                         alt="@item.Title"
                         loading="lazy"
                         onerror="this.onerror=null;this.src='/images/file-icons/no-image.jpg';" />

                    @* Badges *@
                    <div class="badge absolute top-3 right-3 flex flex-col gap-1.5 z-10">
                        @if (isVip)
                        {
                            <div class="px-3 py-1 bg-secondary text-white rounded-full flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                <i data-lucide="star" class="w-3 h-3 fill-white"></i>
                                <span class="text-[10px] font-black uppercase tracking-widest">مميّز</span>
                            </div>
                        }
                        @if (item.DateTo.HasValue && item.DateTo.Value < DateTime.Now.AddDays(7))
                        {
                            <div class="px-3 py-1 bg-white text-red-600 rounded-full flex items-center gap-1 shadow-lg border border-red-100">
                                <i data-lucide="flame" class="w-3 h-3 fill-red-500"></i>
                                <span class="text-[10px] font-black">ينتهي قريباً</span>
                            </div>
                        }
                    </div>

                    @* Wishlist *@
                    <button class="wishlist-btn absolute top-3 left-3 z-10 w-9 h-9 bg-[#f7f4ee]/90 backdrop-blur rounded-full flex items-center justify-center shadow-lg">
                        <i data-lucide="heart" class="w-4 h-4 text-outline"></i>
                    </button>

                    @* File badge *@
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        var fext = System.IO.Path.GetExtension(item.FilePath).ToLower();
                        if (fext == ".pdf" || fext == ".doc" || fext == ".docx" || fext == ".xls" || fext == ".xlsx")
                        {
                            <div class="absolute bottom-3 left-3 z-10 px-2 py-1 bg-black/60 backdrop-blur-sm rounded-lg">
                                <a href="@item.FilePath" target="_blank"
                                   class="text-white text-[10px] font-black flex items-center gap-1">
                                    <i data-lucide="paperclip" class="w-3 h-3"></i> ملف مرفق
                                </a>
                            </div>
                        }
                    }
                </a>

                @* Info *@
                <div class="space-y-1.5 px-1">

                    @* Category tags *@
                    @if (item.Categories != null && item.Categories.Any())
                    {
                        <div class="flex flex-wrap gap-1">
                            @foreach (var cat in item.Categories.Take(2))
                            {
                                <a href="/Hub/SubCategoryAnnouncements/@cat.CategoryId"
                                   class="text-[10px] font-black text-secondary uppercase tracking-widest flex items-center gap-1 hover:underline">
                                    <span class="w-1 h-1 rounded-full bg-secondary inline-block"></span>
                                    @cat.CategoryName
                                </a>
                            }
                        </div>
                    }

                    @* Title *@
                    <a href="/Hub/Details/@item.Id"
                       class="block text-sm font-black tracking-tight text-on-surface group-hover:text-secondary transition-colors duration-200 leading-snug line-clamp-2">
                        @item.Title
                    </a>

                    @* Date + Client *@
                    <div class="flex items-center justify-between text-[10px] font-bold text-outline">
                        @if (item.AddedDate.HasValue)
                        {
                            <span class="flex items-center gap-1">
                                <i data-lucide="calendar" class="w-3 h-3"></i>
                                @DateTimeHelper.FormatDateTime(item.AddedDate)
                            </span>
                        }
                        @if (item.Client != null)
                        {
                            <span class="text-outline-variant truncate max-w-[90px]">@item.Client.ClientName</span>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
}
else
{
    <div class="flex flex-col items-center justify-center py-24 text-center">
        <div class="w-20 h-20 rounded-full bg-[#e6f4f2] flex items-center justify-center mb-5">
            <i data-lucide="search-x" class="w-9 h-9 text-secondary"></i>
        </div>
        <h3 class="text-xl font-black text-on-surface mb-2">لا توجد إعلانات</h3>
        <p class="text-sm font-bold text-outline">لا توجد إعلانات تطابق الفلتر المحدد حالياً</p>
    </div>
}
