@model Search2ViewModel

@if (Model.Announcements != null && Model.Announcements.Any())
{
    <div class="row g-3">
        @foreach (var item in Model.Announcements)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">

                    <div class="card-body">
                        <h6 class="fw-bold">
                            <a asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                        </h6>

                        @if (item.Categories != null)
                        {
                            @foreach (var cat in item.Categories)
                            {
                                <span class="badge bg-secondary me-1">@cat.CategoryName</span>
                            }
                        }

                        <div class="text-muted small mt-2">
                            @item.AddedDate?.ToString("yyyy-MM-dd")
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">لا توجد نتائج.</div>
}
