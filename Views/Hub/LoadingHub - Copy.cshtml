@{
    var parentCategories = ViewBag.ParentCategories as List<Category>;
}

<!-- Modal for displaying PDF -->
<div id="pdfModal" class="modal">
    <div class="modal-content">
        <div id="pdfShareButtons" class="pdf-share" style="display: none;">
            <a id="share-facebook" target="_blank" rel="noopener noreferrer" title="مشاركة على فيسبوك" class="social-btn fb"><i class="fab fa-facebook-f"></i></a>
            <a id="share-twitter" target="_blank" rel="noopener noreferrer" title="مشاركة على تويتر" class="social-btn tw"><i class="fab fa-twitter"></i></a>
            <a id="share-whatsapp" target="_blank" rel="noopener noreferrer" title="مشاركة على واتساب" class="social-btn wa"><i class="fab fa-whatsapp"></i></a>
            <a id="Download" target="_blank" rel="noopener noreferrer" title="تحميل" class="social-btn Dow"><i class="fa-solid fa-download"></i></a>
        </div>
        <span id="closePdfModal" class="close">&times;</span>
        <div id="pdfCanvas"></div>
        <div class="pdf-navigation">
            <button id="prevPageBtn">السابق</button>
            <button id="nextPageBtn">التالي</button>
        </div>
    </div>
</div>

<div>
    <div class="info-box rounded border p-4 mb-2 category-wrapper">
        <div class="main-menu">
            @foreach (var category in parentCategories)
            {
                <div class="category-container">
                    <button class="category-btn" data-category-id="@category.Id">@category.CatName</button>
                </div>
            }
        </div>
        <div class="subcategories-container" id="subcategories-container"></div>
    </div>

    <div id="announcementArea">
        <div id="announcementList" class="row d-flex justify-content-start">
            <p class="d-flex justify-content-center">
                <i class="fas fa-info-circle" style="color:#3498db; margin-left: 6px;"></i>
                اضغط على أحد التصنيفات الفرعية لعرض الإعلانات.
            </p>
        </div>
    </div>
</div>
