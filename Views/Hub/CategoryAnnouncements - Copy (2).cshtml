@model CategoryAnnouncementsViewModel

@{
    ViewBag.Title = $"إعلانات {Model.CategoryName}";
    int totalPages = Model.TotalPages;
    int page = Model.PageNumber;
    int pageSize = Model.PageSize;
}

<div class="container">
    <div class="row g-1">
        <!-- 🔹 Announcements List -->
        <div class="col-md-10">
            <h2>@Model.CategoryName</h2>


            <!-- 🔹 Subcategory Filters (Checkboxes) -->
            <div class="mt-4">
                <h6 class="fw-bold text-secondary">فلتر حسب الفئات الفرعية:</h6>
                <form id="subcategory-filters">
                    @foreach (var subcategory in Model.Subcategories)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="@subcategory.Id" id="subcategory-@subcategory.Id"
                                   name="selectedSubcategories" @(Model.SelectedSubcategories.Contains(subcategory.Id) ? "checked" : "")>
                            <label class="form-check-label" for="subcategory-@subcategory.Id">
                                @subcategory.CatName
                            </label>
                        </div>
                    }
                </form>
            </div>

            <!-- 🔹 Announcements Cards -->
            <div class="row g-1">
                @if (Model.Announcements.Any())
                {
                    @foreach (var item in Model.Announcements)
                    {
                        <div class="col-md-6">
                            <div class="card shadow-sm h-100">
                                <div class="row g-0">
                                    <!-- Thumbnail -->
                                    <div class="col-4 d-flex align-items-center justify-content-center bg-light">
                                        @{
                                            var filePath = item.FilePath;
                                            var extension = System.IO.Path.GetExtension(filePath ?? "").ToLower();
                                            string displayPath = extension switch
                                            {
                                                ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" => filePath,
                                                ".pdf" => Url.Content("~/images/file-icons/pdf-icon.png"),
                                                ".doc" or ".docx" => Url.Content("~/images/file-icons/word-icon.png"),
                                                ".xls" or ".xlsx" => Url.Content("~/images/file-icons/excel-icon.png"),
                                                _ when string.IsNullOrEmpty(filePath) => Url.Content("~/images/file-icons/no-image.jpg"),
                                                _ => Url.Content("~/images/file-icons/file-icon.png")
                                            };
                                        }
                                    <div class="ratio ratio-1x1 bg-white border rounded shadow-sm overflow-hidden m-2">
                                        <img src="@displayPath" alt="Thumbnail" class="w-100 h-100" style="object-fit: cover;" />
                                    </div>
                                </div>

                                <!-- Content -->
                                <div class="col-8">
                                    <div class="card-body">
                                        <h6 class="card-title fw-bold">
                                            <a asp-controller="Hub" asp-action="Details" asp-route-id="@item.Id"
                                               class="text-decoration-none text-primary">
                                                @item.Title
                                            </a>
                                        </h6>
                                        <p class="text-muted small">
                                            @(string.IsNullOrEmpty(item.Description)
                                                                                    ? "لا يوجد وصف"
                                                                                    : item.Description.Length > 80
                                                                                    ? item.Description.Substring(0, 80) + "..."
                                                                                    : item.Description)
                                    </p>
                                    <span class="text-muted small">🗓️ @item.AddedDate?.ToString("yyyy-MM-dd")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                                }
                }
                else
                {
                    <div class="alert alert-info text-center shadow-sm">لا توجد إعلانات في هذا التصنيف حالياً.</div>
                }
            </div>

            <!-- 🔹 Pagination -->
            @if (totalPages > 1)
            {
                <nav aria-label="صفحات">
                    <ul class="pagination justify-content-center mt-4">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == page ? "active" : "")">
                                <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>

        <!-- 🔹 Related Categories Sidebar -
        <div class="col-md-2 border bg-light">
            if (Model.RelatedCategories.Any())
            {
                <div class="mt-3 px-2">
                    <h6 class="fw-bold text-secondary">تصنيفات ذات صلة:</h6>
                    <hr />
                    foreach (var rc in Model.RelatedCategories)
                    {
                        <a asp-controller="Hub" asp-action="CategoryAnnouncements" asp-route-id="rc.Id"
                           class="btn btn-outline-secondary btn-sm text-start mb-2 fw-bold w-100">
                            rc.Name
                        </a>
                    }
                </div>
            }
                </div>-->
    </div>
</div>

<!-- JavaScript for AJAX Filtering and Pagination -->
<script>
    $(document).ready(function () {
        // Trigger filter on checkbox change
        $('input[name="selectedSubcategories"]').change(function () {
            var selectedSubcategories = $('input[name="selectedSubcategories"]:checked').map(function () {
                return this.value;
            }).get();

            // Make AJAX call to filter results
            $.ajax({
                url: '@Url.Action("CategoryAnnouncements", "Hub")',
                data: {
                    id: @Model.CategoryId,
                    selectedSubcategories: selectedSubcategories,
                    page: 1, // Reset to first page when filtering
                    pageSize: @Model.PageSize
                },
                success: function (data) {
                    // Update the page with the new filtered results
                    $('.row.g-1').html(data.announcements); // Update the announcements section
                    $('.pagination').html(data.pagination); // Update the pagination section
                }
            });
        });
    });

    function loadPage(page) {
        $.ajax({
            url: '@Url.Action("CategoryAnnouncements", "Hub")',
            data: {
                id: @Model.CategoryId,
                selectedSubcategories: $('input[name="selectedSubcategories"]:checked').map(function () {
                    return this.value;
                }).get(),
                page: page,
                pageSize: @Model.PageSize
            },
            success: function (data) {
                $('.row.g-1').html(data.announcements); // Update the announcements section
                $('.pagination').html(data.pagination); // Update the pagination section
            }
        });
    }
</script>
