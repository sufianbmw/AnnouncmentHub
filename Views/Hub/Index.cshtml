                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                <div class="absolute top-3 right-3">
                    <span class="px-3 py-1 bg-white/20 backdrop-blur-md text-white text-[10px] font-black rounded-full border border-white/30">كتالوجات الأسبوع</span>
                </div>
                <div class="absolute bottom-0 right-0 p-5 text-right">
                    <h3 class="text-white font-black text-lg md:text-xl tracking-tight leading-tight mb-1">عروض موسمية</h3>
                    <p class="text-white/70 text-xs font-bold">أقوى التخفيضات</p>
