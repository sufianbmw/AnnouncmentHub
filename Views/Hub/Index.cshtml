            <div class="highlight-card group relative rounded-2xl overflow-hidden cursor-pointer aspect-[3/4] reveal reveal-delay-3">
                <img src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&q=80&w=600"
                     class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer">
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute top-3 right-3">
                    <span class="px-3 py-1 bg-[#0d9488]/80 backdrop-blur-md text-white text-[10px] font-black rounded-full">خصم ٢٥٪</span>
