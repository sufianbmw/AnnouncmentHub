@using AnnouncmentHub.Helpers
@model AnnouncmentHub.ViewModels.AnnouncementSearchResult

@* ✅ Local function: منطق الصورة في مكان واحد *@
@{
    string GetDisplayPath(string filePath, List<AnnouncmentHub.Helpers.AnnouncementImageVm> images)
    {
        var extension = System.IO.Path.GetExtension(filePath ?? "").ToLower();
        var imageExts = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp" };

        // 1) FilePath هو صورة → استخدمه مباشرة
        if (!string.IsNullOrEmpty(filePath) && imageExts.Contains(extension))
            return filePath;

        // 2) أول صورة من جدول AnnouncementImage
        var firstDbImage = images?.FirstOrDefault()?.ImageUrl;
        if (!string.IsNullOrEmpty(firstDbImage))
        {
            firstDbImage = firstDbImage.Replace("\\", "/");
            if (!firstDbImage.StartsWith("/"))
                firstDbImage = "/" + firstDbImage;
            return firstDbImage;
        }

        // 3) Fallback حسب نوع الملف
        if (string.IsNullOrEmpty(filePath))                          return "/images/file-icons/no-image.jpg";
        if (extension == ".pdf")                                      return "/images/file-icons/pdf-icon.png";
        if (extension == ".doc" || extension == ".docx")              return "/images/file-icons/word-icon.png";
        if (extension == ".xls" || extension == ".xlsx")              return "/images/file-icons/excel-icon.png";
        return "/images/file-icons/file-icon.png";
    }
}

@if (Model.Announcements != null && Model.Announcements.Any())
{
    <div class="row g-3">
        @foreach (var item in Model.Announcements)
        {
            var displayPath = GetDisplayPath(item.FilePath, item.Images);

            <div class="col-md-3">
                <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden announcement-card">

                    <!-- 🔹 Image Top -->
                    <div class="ratio ratio-4x3 overflow-hidden">
                        <a asp-controller="Hub" asp-action="Details" asp-route-id="@item.Id">
                            <img src="@displayPath"
                                 class="w-100 h-100 announcement-img"
                                 style="object-fit: cover;"
                                 title="@item.Title"
                                 alt="@item.Title"
                                 loading="lazy"
                                 onerror="this.onerror=null;this.src='/images/file-icons/no-image.jpg';" />
                        </a>
                    </div>

                    <!-- 🔹 Card Body -->
                    <div class="card-body d-flex flex-column">

                        <!-- Title -->
                        <h6 class="fw-bold mb-1">
                            <a asp-controller="Hub"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="text-decoration-none text-primary">
                                @item.Title
                            </a>
                        </h6>

                        <!-- Date -->
                        @if (item.AddedDate.HasValue)
                        {
                            <small class="text-muted mb-2">
                                🗓️ @DateTimeHelper.FormatDateTime(item.AddedDate)
                            </small>
                        }

                        <!-- Description -->
                        <p class="small text-muted flex-grow-1">
                            @if (string.IsNullOrEmpty(item.Description))
                            {
                                <text>لا يوجد وصف</text>
                            }
                            else
                            {
                                var desc = item.Description;
                                if (desc.Length > 80)
                                {
                                    var cut = desc.Substring(0, 80);
                                    var lastSpace = cut.LastIndexOf(' ');
                                    @((lastSpace > 0 ? cut.Substring(0, lastSpace) : cut) + "...")
                                }
                                else
                                {
                                    @desc
                                }
                            }
                        </p>

                        <!-- ✅ Categories مع null check -->
                        @if (item.Categories != null && item.Categories.Any())
                        {
                            <div class="mb-2">
                                @foreach (var cat in item.Categories)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">
                                        <a asp-controller="Hub"
                                           asp-action="SubCategoryAnnouncements"
                                           asp-route-id="@cat.CategoryId"
                                           class="text-decoration-none text-white small">
                                            @cat.CategoryName
                                        </a>
                                    </span>
                                }
                            </div>
                        }

                        <!-- File Button -->
                        @if (!string.IsNullOrEmpty(item.FilePath))
                        {
                            <div class="mt-auto">
                                <a href="@item.FilePath"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-info w-100">
                                    📂 فتح الملف
                                </a>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-center text-muted mt-4">لا توجد إعلانات حالياً.</p>
}

