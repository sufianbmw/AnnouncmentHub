@model AnnouncmentHub.ViewModels.AnnouncementViewModel
@using AnnouncmentHub.Helpers

<!-- 🔹 Background -->
<div class="container min-vh-100">
        <!-- Main Card -->
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-4">
             
                      <!-- Title -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                 <div>
                        <h4 class="text-primary fw-bold">@Model.Title</h4>
                        <span class="text-dark text-end">
                            📅 تاريخ الإضافة: @DateTimeHelper.FormatDateTime(Model.AddedDate)
                        </span>
                 </div>  

                    @if (Model.ClientId.HasValue && !string.IsNullOrEmpty(Model.Client?.ClientName))
                    {
                        <div class="card border-0 shadow-sm d-flex align-items-end">
                            <div class="card-body d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(Model?.Client?.LogoUrl) ? Url.Content("~/images/file-icons/no-image.jpg") : Model.Client.LogoUrl)"
                                     alt="@Model.Client?.ClientName" class="rounded-circle border border-2 border-secondary me-3 shadow-sm"
                                     style="width:70px; height:70px; object-fit:cover;" />

                                <h6 class="mb-0 fw-bold">@Model.Client?.ClientName</h6>

                                <a asp-controller="Hub" asp-action="ClientProfile" asp-route-id="@Model.ClientId"
                                   class="small text-decoration-none text-primary">
                                    👀 عرض جميع إعلانات العميل
                                </a>
                            </div>
                        </div>

                    }
              
                </div>

      
            <!-- Description Box -->
            <div class="card mb-2 border-0 shadow-lg bg-light rounded">
                <div class="card-body">
                    <h6 class="fw-bold text-dark mb-3">📝 تفاصيل الإعلان</h6>
                    <hr />
                    <p class="text-muted fs-6 mb-0">
                        @Html.Raw(Model.Description ?? "لا يوجد وصف متاح")
                    </p>
                </div>
            </div>




                <hr />

                <!-- Client Info -->
     


                <!-- Attachment -->
                <div class="mb-4">
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        var extension = System.IO.Path.GetExtension(Model.FilePath).ToLower();

                        if (extension == ".pdf")
                        {
                            <iframe src="~/Scripts/pdfjs/web/viewer.html?file=@Model.FilePath"
                                    width="100%" height="600px"
                                    style="border:none;"
                                    class="rounded shadow-sm"></iframe>
                        }
                        else if (new[] { ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp" }.Contains(extension))
                        {
                            <img src="@Model.FilePath" alt="Attachment"
                                 class="img-fluid rounded shadow-sm" style="max-height:500px;" />
                        }
                        else
                        {
                            <a href="@Model.FilePath" target="_blank" class="btn btn-outline-info">
                                📂 تحميل المرفق
                            </a>
                        }
                    }
                    else
                    {
                        <span class="text-danger">❌ لا يوجد مرفق</span>
                    }
                </div>

                <!-- Back button -->
                <div class="mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i> العودة للقائمة
                    </a>
                </div>
            </div>
        </div>
    </div>

