                        </div>

                    }

              
                </div> *@

      
            <!-- Description Box -->
            <div class="card mb-2 border-0 shadow-lg bg-light rounded">
                <div class="card-body">
                    <h6 class="fw-bold text-dark mb-3">📝 تفاصيل الإعلان</h6>
                    <hr />
                    <p class="text-muted fs-6 mb-0">
                        @Html.Raw(Model.Description ?? "لا يوجد وصف متاح")
                    </p>
                </div>
            </div>

                <hr />
            @if (Model.ImageUrls?.Any() == true)
            {
                <div class="card mb-4 rounded bg-secondary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0">🖼️ معرض الصور</h6>
                            <span class="text-black small">
                                (@Model.ImageUrls.Count صورة)
                            </span>
                        </div>

                        <div id="announcementGallery" class="row g-3">
                            @foreach (var img in Model.ImageUrls)
                            {
                                <div class="col-6 col-md-4 col-lg-3">
                                    <a href="@img"
                                       data-pswp-width="1200"
                                       data-pswp-height="800"
                                       class="gallery-item">
                                        <img src="@img"
                                             loading="lazy"
                                             class="img-fluid rounded-3 border gallery-img p-1" />
                                        <span class="zoom-icon">🔍</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
          

          

                <!-- Attachment -->
                <div class="mb-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        var extension = System.IO.Path.GetExtension(Model.FilePath).ToLower();

                        if (extension == ".pdf")
                        {
                            <iframe src="~/Scripts/pdfjs/web/viewer.html?file=@Model.FilePath"
                                    width="100%" height="600px"
                                    style="border:none;"
                                    class="rounded shadow-sm"></iframe>
                        }
                        else if (new[] { ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp" }.Contains(extension))
                        {
                            <img src="@Model.FilePath" alt="Attachment"
                                 class="img-fluid rounded shadow-sm" style="max-height:500px;" />
                        }
                        else
                        {
                            <a href="@Model.FilePath" target="_blank" class="btn btn-outline-info">
                                📂 تحميل المرفق
                            </a>
                        }
                    }
                    else
                    {
                        <span class="text-danger">❌ لا يوجد مرفق</span>
                    }
                </div>

                <!-- Back button -->
                <div class="mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i> العودة للقائمة
                    </a>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script src="~/js/photoswipe/photoswipe.umd.min.js"></script>
    <script src="~/js/photoswipe/photoswipe-lightbox.umd.min.js"></script>
    <link href="~/css/photoswipe/photoswipe.css" rel="stylesheet" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lightbox = new PhotoSwipeLightbox({
                gallery: '#announcementGallery',
                children: 'a',
                pswpModule: PhotoSwipe
            });
            lightbox.init();
        });
  

        function copyAnnouncementLink() {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
                alert('✅ تم نسخ رابط الإعلان');
            });
        }
  

    </script>
}

