@model AnnouncmentHub.ViewModels.AnnouncementViewModel
@using AnnouncmentHub.Helpers

<!-- 🔹 Background -->
<div class="container min-vh-100">
        <!-- Main Card -->
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-4">
            <!-- Title + Sharing Row -->
            <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap">

                <!-- Left: Title + Date -->
                <div class="me-3 flex-grow-1">
                    <h4 class="text-primary fw-bold mb-1">@Model.Title</h4>
                    <span class="text-dark small">
                        📅 تاريخ الإضافة: @DateTimeHelper.FormatDateTime(Model.AddedDate)
                    </span>
                </div>

                <!-- Right: Sharing Buttons -->
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-success btn-sm"
                       target="_blank"
                       href="https://wa.me/?text=@($"{Model.Title} - {Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")">
                        <i class="bi bi-whatsapp"></i> واتساب
                    </a>

                    <a class="btn btn-primary btn-sm"
                       target="_blank"
                       href="https://www.facebook.com/sharer/sharer.php?u=@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")">
                        <i class="bi bi-facebook"></i> فيسبوك
                    </a>

                    <a class="btn btn-dark btn-sm"
                       target="_blank"
                       href="https://twitter.com/intent/tweet?text=@Model.Title&url=@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")">
                        <i class="bi bi-twitter-x"></i> X
                    </a>

                    <button class="btn btn-outline-secondary btn-sm" onclick="copyAnnouncementLink()">
                        <i class="bi bi-link-45deg"></i> نسخ الرابط
                    </button>
                </div>

            </div>

            <!-- Client Info (if exists) -->
            @if (Model.ClientId.HasValue && !string.IsNullOrEmpty(Model.Client?.ClientName))
            {
                <div class="card border-0 shadow-sm mb-2 align-items-end">
                    <div class="card-body d-flex align-items-center">
                        <img src="@(string.IsNullOrEmpty(Model?.Client?.LogoUrl) ? Url.Content("~/images/file-icons/no-image.jpg") : Model.Client.LogoUrl)"
                             alt="@Model.Client?.ClientName"
                             class="rounded-circle border border-2 border-secondary me-3 shadow-sm"
                             style="width:70px; height:70px; object-fit:cover;" />

                        <div class="d-flex flex-column">
                            <h6 class="mb-1 fw-bold">@Model.Client?.ClientName</h6>
                            <a asp-controller="Hub" asp-action="ClientProfile" asp-route-id="@Model.ClientId"
                               class="small text-decoration-none text-primary">
                                👀 عرض جميع إعلانات العميل
                            </a>
                        </div>
                    </div>
                </div>
            }

