@model AnnouncementSearchResult

@{
    ViewBag.Title = "بحث الإعلانات";
    var query = ViewContext.HttpContext.Request.Query;
    // var selectedCategories = ViewBag.SelectedCategories as string[] ?? Array.Empty<string>();
    var selectedCategories = ViewBag.SelectedCategories as List<int> ?? new List<int>();

    var allCategories = ViewBag.AllCategories as List<CategoryJsonLink> ?? new();
    int page = Model.PageNumber;
    int pageSize = Model.PageSize;
    int totalPages = Model.TotalPages;
}

<!-- 🔎 Filters -->
<form id="searchForm" method="get" asp-action="Search" class="row bg-light rounded border px-2 py-2 mb-2 d-flex justify-content-center">

    <div class="row pb-2 w-100">
        <div class="col d-flex justify-content-center">
            <input type="text" name="title" class="form-control w-75" placeholder="كلمة البحث" value="@query["title"]" />
        </div>
    </div>

    <div class="row w-75 g-3">
        <div class="col-md d-flex justify-content-center align-items-center">
            <label class="form-label mb-0">من تاريخ</label>
        </div>
        <div class="col-md-4">
            <input type="date" name="dateFrom" class="form-control" value="@query["dateFrom"]" />
        </div>
        <div class="col-md d-flex justify-content-center align-items-center">
            <label class="form-label mb-0">إلى تاريخ</label>
        </div>
        <div class="col-md-4">
            <input type="date" name="dateTo" class="form-control" value="@query["dateTo"]" />
        </div>
    </div>

    <!-- Pagination state -->
    <input type="hidden" name="page" value="@(page)" />
    <input type="hidden" name="pageSize" value="@pageSize" />

    <div class="row w-75 my-2">
        <div class="col d-flex justify-content-center gap-2">
            <button type="submit" class="btn btn-primary w-50">بحث</button>
            <button type="button" class="btn btn-outline-secondary" onclick="resetFilters()">🔄 إعادة تعيين الكل</button>
        </div>
    </div>
</form>

<script>
    function resetFilters() {
        const form = document.getElementById('searchForm');
        if (!form) return;
        form.querySelectorAll('input[type="text"], input[type="date"]').forEach(i => i.value = '');
        form.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
        form.querySelector('input[name="page"]').value = 1;
        form.submit();
    }

    function submitPage(pageNumber) {
        const form = document.getElementById('searchForm');
        form.querySelector('input[name="page"]').value = pageNumber;
        form.submit();
    }
</script>

<div class="row">
    <!-- 🔹 Sidebar -->
    <div id="categorySidebar" class="col-md-2 border h-100 pt-3 bg-light">
        <h6 class="fw-bold mb-3">التصنيفات</h6>

        @foreach (var cat in allCategories)
        {
            bool isChecked = selectedCategories.Contains(cat.CategoryId);

            <div class="form-check mb-2">
                <input type="checkbox"
                       class="form-check-input"
                       form="searchForm"
                       name="categoryIds"
                       id="aside-@cat.CategoryId"
                       value="@cat.CategoryId"
                       @(isChecked ? "checked" : "")
                       onchange="document.getElementById('searchForm').submit();" />

                <label for="aside-@cat.CategoryId"
                       class="form-check-label text-nowrap">
                    @cat.CategoryName
                </label>
            </div>
        }
    </div>

    <!-- 🔹 Results -->
    <div class="col-md-10">
        @if (Model != null && Model.Announcements.Any())
        {
            <div class="row g-3">
                @foreach (var item in Model.Announcements)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100">
                            <!-- Thumbnail -->
                            @{
                                var filePath = item.FilePath;
                                var extension = System.IO.Path.GetExtension(filePath ?? "").ToLower();
                                string displayPath = extension switch
                                {   ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" => filePath,
                                    ".pdf" => Url.Content("~/images/file-icons/pdf-icon.png"),
                                    ".doc" or ".docx" => Url.Content("~/images/file-icons/word-icon.png"),
                                    ".xls" or ".xlsx" => Url.Content("~/images/file-icons/excel-icon.png"),
                                    _ when string.IsNullOrEmpty(filePath) => Url.Content("~/images/file-icons/no-image.jpg"),
                                    _ => Url.Content("~/images/file-icons/file-icon.png")
                                };
                            }
                            <div class="ratio ratio-4x3 bg-white border-bottom overflow-hidden">
                                <img src="@displayPath" alt="Thumbnail" class="w-100 h-100" style="object-fit: cover;" />
                            </div>

                            <!-- Content -->
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title fw-bold">
                                    <a asp-controller="Hub"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="text-decoration-none text-primary">
                                        @item.Title
                                    </a>
                                </h6>

                                <p class="text-secondary small mb-2">الإعلان موجود في</p>
                                <p>
                                    @foreach (var cat in item.Categories)
                                    {
                                        <span class="badge bg-secondary me-1">
                                           <a asp-controller="Hub" class="text-decoration-none text-white small" asp-action="CategoryAnnouncements" asp-route-id="@cat.CategoryId">
                                                @cat.CategoryName
                                            </a>
                                        </span>
                                    }
                                </p>

                                @if (item.ClientId.HasValue && !string.IsNullOrEmpty(item.Client?.ClientName))
                                {
                                    <p class="fw-bold text-muted mt-auto">
                                        <a href="@Url.Action("ClientProfile", "Hub", new { id = item.ClientId })"
                                           class="text-decoration-none">
                                            للمعلن @item.Client.ClientName
                                        </a>
                                    </p>
                                }

                                <small class="text-muted">🗓️ @(item.AddedDate?.ToString("yyyy-MM-dd"))</small>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" href="javascript:void(0);" onclick="submitPage(@i)">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
        else
        {
            <div class="alert alert-info d-flex justify-content-center">لا توجد نتائج حالياً.</div>
        }
    </div>
</div>

