@using AnnouncmentHub.ViewModels
@model List<BreadcrumbItem>

@if (Model != null && Model.Any())
{
    <nav class="breadcrumb-nav flex items-center gap-1.5 text-xs font-bold flex-wrap">
        <a href="/" class="breadcrumb-crumb flex items-center gap-1 text-on-surface-variant hover:text-secondary transition-colors duration-200">
            <i data-lucide="house" class="w-3.5 h-3.5"></i>
            الرئيسية
        </a>
        @foreach (var item in Model)
        {
            <i data-lucide="chevron-left" class="w-3 h-3 text-outline flex-shrink-0"></i>
            if (item == Model.Last())
            {
                <span class="text-secondary font-black">@item.Name</span>
            }
            else
            {
                <a href="~/@(item.Url)@(item.Id)"
                   class="breadcrumb-crumb text-on-surface-variant hover:text-secondary transition-colors duration-200">
                    @item.Name
                </a>
            }
        }
    </nav>
}
