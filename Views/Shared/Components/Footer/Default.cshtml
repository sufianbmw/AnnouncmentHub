@using AnnouncmentHub.Models
@model List<AnnouncmentHub.Models.Page>

@if (Model != null && Model.Any())
{
    <div class="space-y-4">
        <h4 class="text-xs font-black uppercase tracking-widest text-secondary">صفحات</h4>
        <ul class="space-y-3">
            @foreach (var page in Model)
            {
                <li>
                    <a href="/Hub/Page/@(page.Id)"
                       class="footer-link text-xs font-bold text-on-surface-variant">
                        @(page.PageTitle)
                    </a>
                </li>
            }
        </ul>
    </div>
}
