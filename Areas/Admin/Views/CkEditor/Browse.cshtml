        //                 // ✅ Refresh grid after upload using current filter
        //                 const currentFilter = $('input[name="fileFilter"]:checked').val();
        //                 refreshFileGrid(currentFilter);
        //                 $('#uploadInput').val('');
        //             } else {
        //                 $('#uploadMsg')
        //                     .text(res.error?.message || res.message || 'فشل التحميل')
        //                     .removeClass('text-success')
        //                     .addClass('text-danger');
        //             }
        //         },
        //         error: function () {
        //             $progress.hide();
        //             $('#uploadMsg').text('⚠️ حدث خطأ أثناء تحميل الملف.').addClass('text-danger');
        //         }
        //     });
        // });


             // =========================
            // 📤 📤 Upload multiple files (AJAX)
            // =========================
                //
                        // 📤 Upload multiple files (AJAX)
        $('#uploadForm').on('submit', function (e) {
            e.preventDefault();
            const files = $('#uploadInput')[0].files;

            if (!files.length) return alert('يرجى اختيار الملفات أولاً.');

            // Show progress bar and reset it for each file upload
            const $progress = $('.progress');
            const $bar = $('#uploadProgressBar');
            $progress.show();
            $bar.css('width', '0%');

            let filesUploaded = 0;  // Counter to track uploaded files

            // Loop through each selected file and upload them individually
            for (let i = 0; i < files.length; i++) {
                const formData = new FormData();
                formData.append('upload', files[i]);

                $.ajax({
                    url: '/CkEditor/Upload',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    xhr: function () {
                        const xhr = new window.XMLHttpRequest();
                        // Track progress for each file
                        xhr.upload.addEventListener('progress', function (evt) {
                            if (evt.lengthComputable) {
                                const percent = Math.round((evt.loaded / evt.total) * 100);
                                $bar.css('width', percent + '%');
                            }
                        }, false);
                        return xhr;
                    },
                    success: function (res) {
                        filesUploaded++;  // Increment counter for each successful upload
                        $bar.css('width', '100%');
                        setTimeout(() => $progress.fadeOut(), 500);

                        if (res.uploaded === 1 || res.success) {
                            $('#uploadMsg')
                                .text(`${files[i].name} تم تحميله بنجاح`)
                                .removeClass('text-danger')
                                .addClass('text-success');

                            // Append new file card dynamically
                            appendFileCard(res.url, res.fileName);
                        } else {
                            $('#uploadMsg')
                                .text(`${files[i].name} فشل التحميل`)
                                .removeClass('text-success')
                                .addClass('text-danger');
                        }

                        // If all files are uploaded, refresh the grid
                        if (filesUploaded === files.length) {
                            const currentFilter = $('input[name="fileFilter"]:checked').val();
                            refreshFileGrid(currentFilter);  // Refresh the file grid
                        }
                    },
                    error: function () {
                        $('#uploadMsg').text('⚠️ حدث خطأ أثناء تحميل الملف.').addClass('text-danger');
                    }
                });
            }

            // Reset input field after upload
            $('#uploadInput').val('');
        });


                          function appendFileCard(url, fileName) {
            const fileExtension = fileName.split('.').pop().toLowerCase();  // Get the file extension
            const isImage = ['jpg', 'jpeg', 'png', 'gif', 'webp'].includes(fileExtension);
            let cardHtml = '';

            if (isImage) {
                // For Image Files
                cardHtml = `
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2 file-card is-image">

                        <img class="file-preview" src="${url}" title="${fileName}" alt="${fileName}" />
                        <span class="file-name">${fileName}</span>
                        <hr>
                        <button class="delete-btn" data-file="${fileName}">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>`;
            } else {
                // For Non-Image Files (PDF, DOCX, ZIP, etc.)
                let iconPath;
                let downloadLink = `/uploads/${fileName}`;  // The download path for the file

                // Choose the icon for the file based on extension
                switch (fileExtension) {
                    case 'pdf': iconPath = '/uploads/icons/pdf.png'; break;
                    case 'doc': case 'docx': iconPath = '/uploads/icons/word.png'; break;
                    case 'xls': case 'xlsx': iconPath = '/uploads/icons/excel.png'; break;
                    case 'zip': case 'rar': iconPath = '/uploads/icons/zip.png'; break;
                    case 'txt': iconPath = '/uploads/icons/txt.png'; break;
                    default: iconPath = '/uploads/icons/file.png'; break;  // Default icon for unknown file types
                }

                // File card for non-image types with a download button
                cardHtml = `
                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 file-card is-file">
                        <img class="file-preview" src="${iconPath}" title="${fileName}" alt="${fileName}" />
                        <span class="file-name">${fileName}</span>
                        <hr>
                        <a href="${downloadLink}" download class="Download-btn text-decoration-none" target="_blank">
                            <i class="fas fa-download"></i> 
                        </a>
                        |
                        <button class="delete-btn" data-file="${fileName}">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>`;
            }

            // Prepend the new file card to the grid for immediate display
            $('#browseFile').prepend(cardHtml);
        }



            // =========================
            // 🧩 Filter buttons
            // =========================
            $('input[name="fileFilter"]').on('change', function () {
                const filter = $(this).val();
                refreshFileGrid(filter); // reload from server dynamically
            });
                    // 🔁 Manual refresh button
        $('#refreshBtn').on('click', function () {
            const filter = $('input[name="fileFilter"]:checked').val();
            refreshFileGrid(filter);
        });

            // =========================
            // 🗑️ Delete file
            // =========================
            $(document).on('click', '.delete-btn', function () {
                const fileName = $(this).data('file');
                if (confirm('هل أنت متأكد أنك تريد حذف "' + fileName + '"؟')) {
                    $.ajax({
                        url: '/CkEditor/Delete',
                        type: 'POST', // using POST for reliability
                        data: { fileName: fileName },
                        success: function (res) {
                            if (res.success) {
                                const currentFilter = $('input[name="fileFilter"]:checked').val();
                                refreshFileGrid(currentFilter); // ✅ refresh after delete
                            } else {
                                alert(res.message);
                            }
                        },
                        error: function () {
                            alert('حدث خطأ أثناء حذف الملف.');
                        }
                    });
                }
            });
        });
    </script>

</body>
</html>
