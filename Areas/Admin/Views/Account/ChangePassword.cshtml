@model ChangePasswordViewModel

@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="container py-4">

    <!-- Header -->
    <div class="card shadow-sm border-0 rounded-4 mb-4 text-center">
        <div class="card-body">
            <h2 class="fw-bold text-primary">🔐 تغيير كلمة المرور</h2>
            <p class="text-muted">قم بتحديث كلمة المرور الخاصة بك بأمان</p>
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["SuccessMessage"]
                    <button class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post" class="row g-4">

                <!-- Current Password -->
                <div class="col-12">
                    <div class="form-floating">
                        <input asp-for="CurrentPassword" class="form-control" placeholder="كلمة المرور الحالية" />
                        <label asp-for="CurrentPassword">🔑 كلمة المرور الحالية</label>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                </div>

                <!-- New Password -->
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="NewPassword" class="form-control" placeholder="كلمة المرور الجديدة" />
                        <label asp-for="NewPassword">🔐 كلمة المرور الجديدة</label>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Confirm -->
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="تأكيد كلمة المرور" />
                        <label asp-for="ConfirmPassword">✅ تأكيد كلمة المرور</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>

                <!-- Button -->
                <div class="col-12 text-center mt-3">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
                        💾 حفظ التغيير
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}