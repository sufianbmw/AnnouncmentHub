@model ProfileFormViewModel

@{
    ViewData["Title"] = "حذف المستخدمين";
}

<div class="container py-4">

    <!-- Header -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body text-center">
            <h2 class="fw-bold text-danger mb-1">🗑️ حذف المستخدم</h2>
            <p class="text-muted mb-0">يرجى التأكد من البيانات قبل تنفيذ الحذف ⚠️</p>
        </div>
    </div>

    <!-- Delete Card -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-danger text-white fw-bold rounded-top-4">
            ⚠️ تأكيد حذف المستخدم
        </div>

        <div class="card-body p-4">

            <div class="alert alert-warning text-center rounded-3 fw-bold">
                هل أنت متأكد من حذف هذا المستخدم؟ 🚨
            </div>

            <div class="row g-3">

                <div class="col-md-6">
                    <div class="p-3 bg-light border rounded-4 h-100">
                        <label class="text-muted small mb-1">🧍 الاسم الأول</label>
                        <div class="fw-bold fs-5">@Html.DisplayFor(model => model.FName)</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 bg-light border rounded-4 h-100">
                        <label class="text-muted small mb-1">🧍‍♂️ الاسم الأخير</label>
                        <div class="fw-bold fs-5">@Html.DisplayFor(model => model.LName)</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 bg-light border rounded-4 h-100">
                        <label class="text-muted small mb-1">📧 البريد الإلكتروني</label>
                        <div class="fw-bold fs-5">@Html.DisplayFor(model => model.Email)</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 bg-light border rounded-4 h-100">
                        <label class="text-muted small mb-1">👤 اسم المستخدم</label>
                        <div class="fw-bold fs-5">@Html.DisplayFor(model => model.UserName)</div>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="p-3 bg-light border rounded-4 h-100">
                        <label class="text-muted small mb-1">🔒 حالة الحساب</label>
                        <div class="fw-bold fs-5">
                            @(Model.UserStatus ? "✅ مفعل" : "❌ غير مفعل")
                        </div>
                    </div>
                </div>

            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                @if (TempData["ErorrMessage"] != null)
                {
                    <div id="alert" class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                        <strong>❌ @TempData["ErorrMessage"]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <hr />

                <div class="text-center">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill px-4 fw-bold">
                        🗑️ حذف
                    </button>

                    <a asp-action="Index" class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-bold ms-2">
                        🔙 رجوع
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}