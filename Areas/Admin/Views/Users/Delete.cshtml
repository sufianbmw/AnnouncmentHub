@model ProfileFormViewModel

@{
    ViewData["Title"] = "حذف المستخدمين";

}


<div class="shadow-lg p-3 m-5 bg-white rounded">
    <h5>هل أنت متاكد من حذف المستخدم ؟</h5>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.LName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UserName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>
  
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UserStatus)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserStatus)
        </dd>
    </dl>
    <hr />
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        @if (TempData["ErorrMessage"] != null)
        {
            <div id="alert" class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
                <strong>
                    @TempData["ErorrMessage"] !
                </strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>

            </div>

        }
        <div class="form-group text-center">
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i>
                حــذف
            </button> |
            <a asp-action="Index" class="btn btn-primary">
                <i class="fas fa-arrow-alt-circle-left"></i>
                رجــوع
            </a>
        </div>
    </form>
</div>
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
 
}



