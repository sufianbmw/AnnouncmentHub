@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">مرحباً بك في لوحة التحكم 👋</h2>

    <div class="row g-4">
        <!-- 🔹 التصنيفات -->
        <div class="col-md-3 col-sm-6">
            <div class="card text-center shadow-sm border-0 p-3 dashboard-card">
                <i class="fa fa-layer-group fa-2x text-primary mb-1"></i>
                <h5 class="fw-bold">التصنيفات</h5>
                <label class="text-muted">تصنيف رئيسي: <strong>@(ViewBag.CategoryCount ?? 0)</strong></label>
                <label class="text-muted">تصنيف فرعي: <strong>@(ViewBag.SubCategoryCount ?? 0)</strong></label>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-primary mt-2">إدارة

                    التصنيفات
                </a>
            </div>
        </div>

        <!-- 🔹 العملاء -->
        <div class="col-md-3 col-sm-6">
            <div class="card text-center shadow-sm border-0 p-3 dashboard-card">
                <i class="fa fa-user-tie fa-2x text-warning mb-2"></i>
                <h5 class="fw-bold">العملاء</h5>
                <p class="text-muted">عدد العملاء: <strong>@(ViewBag.ClientCount ?? 0)</strong></p>
                <a asp-area="Admin" asp-controller="Clients" asp-action="Index" class="btn btn-sm btn-outline-warning mt-2">
                    إدارة
                    العملاء
                </a>
            </div>
        </div>

        <!-- 🔹 الإعلانات -->
        <div class="col-md-3 col-sm-6">
            <div class="card text-center shadow-sm border-0 p-3 dashboard-card">
                <i class="fa fa-bullhorn fa-2x text-info mb-2"></i>
                <h5 class="fw-bold">الإعلانات</h5>
                <p class="text-muted">
                    عدد الإعلانات: <strong>@(ViewBag.AdsCount ?? 0)</strong>
                </p>
                <a asp-area="Admin" asp-controller="Announcements" asp-action="Index" class="btn btn-sm btn-outline-info mt-2">
                    إدارة
                    الإعلانات
                </a>
            </div>
        </div>
        <!-- 🔹 الصفحات -->
        <div class="col-md-3 col-sm-6">
            <div class="card text-center shadow-sm border-0 p-3 dashboard-card">
                <i class="fa fa-file-alt fa-2x text-danger mb-2"></i> <!-- Updated to fa-file-alt -->
                <h5 class="fw-bold">الصفحات</h5>
                <p class="text-danger">
                    عدد الصفحات: <strong>@(ViewBag.pagesCount ?? 0)</strong>
                </p>
                <a asp-area="Admin" asp-controller="pages" asp-action="Index" class="btn btn-sm btn-outline-danger mt-2">
                    إدارة الصفحات
                </a>
            </div>
        </div>


        <!-- 🔹 المستخدمون -->
        <div class="col-md-3 col-sm-6">
            <div class="card text-center shadow-sm border-0 p-3 dashboard-card">
                <i class="fa fa-users fa-2x text-success mb-2"></i>
                <h5 class="fw-bold">المستخدمون</h5>
                <p class="text-muted">عدد المستخدمين: <strong>@(ViewBag.UsersCount ?? 0)</strong></p>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-sm btn-outline-success mt-2">إدارة</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Future: add small dashboard interactions or chart initialization here
        console.log("Dashboard loaded successfully!");
    </script>
}
