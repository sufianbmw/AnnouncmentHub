<!-- ✅ Enable Client-Side Validation -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            // Load subcategories based on selected parent category
            $('#ParentCategory').on('change', function () {
                var parentId = $(this).val();
                var subCategoryDropdown = $('#SubCategory');

                subCategoryDropdown.empty(); // ✅ Clear existing options

                if (parentId && parentId !== "-1") {
                    $.ajax({
                        url: '/Announcements/GetSubcategories',
                        type: 'GET',
                        data: { parentId: parentId },
                        dataType: 'json',
                        success: function (subcategories) {
                            $.each(subcategories, function (i, category) {
                                subCategoryDropdown.append(
                                    $('<option></option>').attr('value', category.id).text(category.catName)
                                );
                            });

                            // ✅ Preserve previously selected subcategory
                            var selectedSubCategoryId = '@Model.CategoryId';
                            if (selectedSubCategoryId) {
                                subCategoryDropdown.val(selectedSubCategoryId);
                            }
                        },
                        error: function () {
                            alert('⚠️ حدث خطأ أثناء تحميل التصنيفات الفرعية!');
                        }
                    });
                }
            });

            // ✅ Preserve parent category selection
            var selectedParentCategoryId = '@ViewBag.ParentCategoryId';
            if (selectedParentCategoryId) {
                $('#ParentCategory').val(selectedParentCategoryId).trigger('change');
            }
        });
    </script>
}
