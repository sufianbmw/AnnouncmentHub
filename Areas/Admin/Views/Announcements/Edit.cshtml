@model AnnouncmentHub.ViewModels.AnnouncementViewModel

@{
    ViewData["Title"] = "✏️ تعديل الإعلان";
}

<div class="card shadow-sm rounded border border-primary p-4 bg-light">
    <h5 class="mb-4 text-primary text-center">@ViewData["Title"]</h5>
    <hr />
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
    <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col mb-3">
                <label asp-for="Title" class="form-label">📛 @Html.DisplayNameFor(m => m.Title)</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

 
        </div>
        <div class="row">
            <div class="col mb-3">
                <label asp-for="Description" class="form-label">📝 @Html.DisplayNameFor(m => m.Description)</label>
                @*                 <textarea asp-for="Description" class="form-control" rows="2"></textarea>
 *@                <textarea asp-for="Description" class="form-control" id="editor"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>

       
            @if (Model.ExistingImages != null && Model.ExistingImages.Any())
            {
            <div class="mb-4 border rounded p-2 h-100 text-center bg-light">
                    <label class="form-label fw-bold">الصور الحالية</label>

                    <div class="row g-3">
                        @foreach (var img in Model.ExistingImages)
                        {
                            <div class="col-6 col-md-3">
                                <div class="position-relative border rounded p-2 h-100 text-center bg-light">
                                <img src="@img.ImageUrl" class="img-thumbnail mb-2" style="height:120px">

                             @*    <button type="button"
                                        class="btn btn-sm btn-danger"
                                        onclick="deleteImage(@img.Id, this)">
                                    🗑 حذف
                                </button> *@

                                <button type="button"
                                        class="btn btn-sm btn-danger"
                                        onclick="deleteImage(@img.Id)">
                                    🗑️ حذف
                                </button>


                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        <div class="mb-3">
            <label class="form-label fw-bold">إضافة صور جديدة</label>
            <input type="file" name="ImageFiles" class="form-control" multiple accept="image/*" />
            <small class="text-muted">
                يمكنك رفع أكثر من صورة (JPG, PNG)
            </small>
        </div>

       
        <div class="row">
            <div class="col mb-3">
                <label asp-for="File" class="form-label">📎 @Html.DisplayNameFor(m => m.File)</label>
                <input asp-for="File" type="file" class="form-control" />
                <span asp-validation-for="File" class="text-danger"></span>

                @if (!string.IsNullOrEmpty(Model.FilePath))
                {
                    <p class="mt-2">ملف مرفق حالي: <a href="@Model.FilePath" target="_blank">فتح الملف</a></p>
                }
            </div>
            <!-- Client Dropdown -->
            <div class="col mb-3">
                <label asp-for="ClientId" class="form-label">👥 @Html.DisplayNameFor(m => m.ClientId)</label>
                <select asp-for="ClientId" class="form-control">
                    <option value="" disabled selected>-- اختر العميل --</option>
                    @if (ViewBag.Clients != null && ((IEnumerable<SelectListItem>)ViewBag.Clients).Any())
                    {
                        foreach (var client in (IEnumerable<SelectListItem>)ViewBag.Clients)
                        {
                            <option value="@client.Value">@client.Text</option>
                        }
                    }
                    else
                    {
                        <option>No clients available</option>
                    }
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
        </div>
        <div class="row">
            <!-- Date From (Start Date) -->
            <div class="col mb-3">
                <label asp-for="DateFrom" class="form-label">🗓️ @Html.DisplayNameFor(m => m.DateFrom)</label>
                <input asp-for="DateFrom" type="date" class="form-control" />
                <span asp-validation-for="DateFrom" class="text-danger"></span>
            </div>

            <!-- Date To (End Date) -->
            <div class="col mb-3">
                <label asp-for="DateTo" class="form-label">🗓️ @Html.DisplayNameFor(m => m.DateTo)</label>
                <input asp-for="DateTo" type="date" class="form-control" />
                <span asp-validation-for="DateTo" class="text-danger"></span>
            </div>
        </div>
    <div class="container mt-2">
        <div class="card shadow p-4 mb-4 rounded border border-primary bg-light">
            <h5 class="card-title">📂 التصنيفات الفرعية</h5>
            <div class="row p-2">
                @foreach (var subcategoryItem in ViewBag.SubCategoriesWithParents)
                {
                    <div class="col-md-4 mb-2">
                        <div class="form-check d-flex justify-content-start border rounded p-2">
                                <input class="form-check-input mx-1 fs-6" type="checkbox" value="@subcategoryItem.SubCategoryId" id="subcategory@(subcategoryItem.SubCategoryId)" name="SelectedSubCategories[]"
                                       @(Model.SelectedSubCategories.Contains(subcategoryItem.SubCategoryId) ? "checked" : "") />  
                                       <label class="form-check-label" for="subcategory@(subcategoryItem.SubCategoryId)">
                                @subcategoryItem.SubCategoryName
                                <span class="text-muted">(@string.Join(", ", subcategoryItem.ParentCategories))</span>
                            </label>
                         
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>


    <div class="form-check form-switch mb-4">
        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="IsActiveCheckbox" />
        <label asp-for="IsActive" class="form-check-label">✅ مفعل</label>
    </div>
        <div class="col d-flex justify-content-center">
            <button type="submit" class="btn btn-success me-2 w-25">💾 حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-secondary w-25">↩️ إلغاء</a>

        </div>
</form>
</div>
