@* Usage: @await Html.PartialAsync("_IconPicker", Model.IconName) *@
@model string

@{
    var icons = new[]
    {
        // Real Estate
        "building-2","home","warehouse","hotel","landmark","castle","store","door-open","key","fence",
        // Vehicles
        "car","truck","bus","bike","plane","ship","train-front","tractor","fuel","map-pin",
        // Electronics
        "smartphone","laptop","monitor","tablet","tv","headphones","camera","cpu","printer","wifi",
        // Fashion
        "shirt","watch","gem","glasses","shopping-bag","backpack","tag","package",
        // Jobs & Work
        "briefcase","hard-hat","stethoscope","scale","hammer","wrench","code-2","chef-hat","graduation-cap","pencil",
        // Food
        "utensils","coffee","pizza","apple","beef","cookie","wine","sandwich","salad","ice-cream-cone",
        // Furniture & Home
        "sofa","lamp","armchair","bed","bath","refrigerator","microwave","flower-2","paintbrush","scissors",
        // Sports
        "dumbbell","trophy","target","timer","medal","activity","heart-pulse","volleyball","swords","zap",
        // Services & Misc
        "gavel","sparkles","leaf","sun","globe","music","palette","megaphone","layers","settings",
        // Communication
        "phone","mail","message-circle","radio","satellite","antenna","signal","bluetooth","share-2","link"
    };
}

<div class="mb-4">
    <label class="form-label fw-semibold">🎨 أيقونة التصنيف (Lucide)</label>

    @* Hidden input that stores the selected icon name *@
    <input type="hidden" name="IconName" id="IconName" value="@Model" />

    @* Search *@
    <input type="text" id="iconSearch" class="form-control mb-2" placeholder="ابحث عن أيقونة... (car, home, ...)" />

    @* Preview of current *@
    <div class="d-flex align-items-center gap-3 mb-3 p-3 border rounded bg-light">
        <div id="iconPreviewBox"
             style="width:52px;height:52px;border-radius:14px;background:#e6f4f2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i id="iconPreviewIcon" data-lucide="@(string.IsNullOrEmpty(Model) ? "tag" : Model)"
               style="width:26px;height:26px;color:#0d9488;"></i>
        </div>
        <div>
            <div class="fw-bold text-dark" id="iconPreviewLabel">
                @(string.IsNullOrEmpty(Model) ? "لم يتم الاختيار" : Model)
            </div>
            <small class="text-muted">انقر على أيقونة أدناه لاختيارها</small>
        </div>
    </div>

    @* Grid *@
    <div id="iconGrid"
         style="display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;max-height:340px;overflow-y:auto;padding:4px;border:1px solid #dee2e6;border-radius:8px;background:#fff;">
        @foreach (var icon in icons)
        {
            <button type="button"
                    class="icon-pick-btn @(Model == icon ? "active" : "")"
                    data-icon="@icon"
                    title="@icon"
                    style="display:flex;flex-direction:column;align-items:center;gap:5px;padding:10px 4px;border:2px solid @(Model == icon ? "#0d9488" : "#e8e4d8");border-radius:10px;background:@(Model == icon ? "#e6f4f2" : "#f7f4ee");cursor:pointer;transition:all .15s;font-size:0;">
                <i data-lucide="@icon" style="width:22px;height:22px;color:@(Model == icon ? "#0d9488" : "#555");pointer-events:none;"></i>
                <span style="font-size:9px;font-weight:700;color:#888;text-align:center;line-height:1.2;word-break:break-all;pointer-events:none;">@icon</span>
            </button>
        }
    </div>
    <small class="text-muted d-block mt-1">@icons.Length أيقونة متاحة — يمكنك أيضاً كتابة الاسم مباشرة في خانة البحث ثم الضغط Enter</small>
</div>

<script>
(function(){
    const input    = document.getElementById('IconName');
    const search   = document.getElementById('iconSearch');
    const grid     = document.getElementById('iconGrid');
    const prevIcon = document.getElementById('iconPreviewIcon');
    const prevLbl  = document.getElementById('iconPreviewLabel');
    const btns     = grid.querySelectorAll('.icon-pick-btn');

    function selectIcon(name) {
        input.value = name;
        prevLbl.textContent = name;
        prevIcon.setAttribute('data-lucide', name);
        lucide.createIcons();
        btns.forEach(b => {
            const active = b.dataset.icon === name;
            b.style.borderColor   = active ? '#0d9488' : '#e8e4d8';
            b.style.background    = active ? '#e6f4f2' : '#f7f4ee';
            b.querySelector('i').style.color = active ? '#0d9488' : '#555';
        });
    }

    btns.forEach(btn => {
        btn.addEventListener('click', () => selectIcon(btn.dataset.icon));
    });

    // Search filter
    search.addEventListener('input', function(){
        const q = this.value.toLowerCase();
        btns.forEach(b => {
            b.style.display = b.dataset.icon.includes(q) ? 'flex' : 'none';
        });
    });

    // Press Enter to manually type icon name
    search.addEventListener('keydown', function(e){
        if (e.key === 'Enter') {
            e.preventDefault();
            const val = this.value.trim();
            if (val) selectIcon(val);
        }
    });
})();
</script>
