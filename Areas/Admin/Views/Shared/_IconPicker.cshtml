@* Pure HTML — scripts live in the page's @section Scripts *@
@model string

@{
    var icons = new[]
    {
        "building-2","home","warehouse","hotel","landmark","castle","store","door-open","key","fence",
        "car","truck","bus","bike","plane","ship","train-front","tractor","fuel","map-pin",
        "smartphone","laptop","monitor","tablet","tv","headphones","camera","cpu","printer","wifi",
        "shirt","watch","gem","glasses","shopping-bag","backpack","tag","package",
        "briefcase","hard-hat","stethoscope","scale","hammer","wrench","code-2","chef-hat","graduation-cap","pencil",
        "utensils","coffee","pizza","apple","beef","cookie","wine","sandwich","salad","ice-cream-cone",
        "sofa","lamp","armchair","bed","bath","refrigerator","microwave","flower-2","paintbrush","scissors",
        "dumbbell","trophy","target","timer","medal","activity","heart-pulse","volleyball","swords","zap",
        "gavel","sparkles","leaf","sun","globe","music","palette","megaphone","layers","settings",
        "phone","mail","message-circle","radio","satellite","antenna","signal","bluetooth","share-2","link"
    };
}

<div class="mb-4">
    <label class="form-label fw-semibold">🎨 أيقونة التصنيف</label>

    <input type="hidden" name="IconName" id="IconName" value="@Model" />

    <input type="text" id="iconSearch" class="form-control mb-2"
           placeholder="ابحث عن أيقونة... (car, home, building...)" autocomplete="off" />

    @* Preview *@
    <div class="d-flex align-items-center gap-3 mb-3 p-3 border rounded" style="background:#f8f9fa;">
        <div style="width:52px;height:52px;border-radius:14px;background:#e6f4f2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i id="iconPreviewIcon"
               data-lucide="@(string.IsNullOrEmpty(Model) ? "tag" : Model)"
               style="width:26px;height:26px;color:#0d9488;"></i>
        </div>
        <div>
            <div class="fw-bold" id="iconPreviewLabel">
                @(string.IsNullOrEmpty(Model) ? "لم يتم الاختيار" : Model)
            </div>
            <small class="text-muted">انقر على أيقونة أدناه لاختيارها</small>
        </div>
    </div>

    @* Icon grid *@
    <div id="iconGrid"
         style="display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;max-height:360px;overflow-y:auto;padding:6px;border:1px solid #dee2e6;border-radius:8px;background:#fff;">
        @foreach (var icon in icons)
        {
            bool active = Model == icon;
            <button type="button" class="icon-pick-btn" data-icon="@icon" title="@icon"
                    style="display:flex;flex-direction:column;align-items:center;gap:5px;padding:10px 4px;
                               border:2px solid @(active ? "#0d9488" : "#e0ddd4");
                               border-radius:10px;background:@(active ? "#e6f4f2" : "#f7f4ee");cursor:pointer;transition:all .15s;">
                <i data-lucide="@icon"
                   style="width:22px;height:22px;color:@(active ? "#0d9488" : "#555");pointer-events:none;"></i>
                <span style="font-size:9px;font-weight:700;color:#888;text-align:center;line-height:1.2;word-break:break-all;pointer-events:none;">@icon</span>
            </button>
        }
    </div>
    <small class="text-muted d-block mt-1">@icons.Length أيقونة متاحة</small>
</div>
