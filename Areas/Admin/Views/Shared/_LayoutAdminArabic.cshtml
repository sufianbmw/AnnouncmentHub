<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم | جو أوفر</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/admin-ar.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />

</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- 🔹 Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color:#1abc9c;border-bottom:3px solid #e74c3c;">

        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <img src="~/images/joofferslogo.png" alt="Jo Offers Logo" style="height:45px;" class="ms-2" />
                لوحة تحكم جو أوفر
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="adminNavbar">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold"
                               asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                🏠 الرئيسية
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold"
                               asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                📂 التصنيفات
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold"
                               asp-area="Admin" asp-controller="Clients" asp-action="Index">
                                🤝 العملاء
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold"
                               asp-area="Admin" asp-controller="Announcements" asp-action="Index">
                                📢 الإعلانات
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold"
                               asp-area="Admin" asp-controller="Pages" asp-action="Index">
                                📄 الصفحات
                            </a>
                        </li>

                        @* ✅ هذان العنصران يظهران فقط للمدير Admin *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-danger"
                                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                                    👥 المستخدمون
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-danger"
                                   asp-area="Admin" asp-controller="Roles" asp-action="Index">
                                    🛡️ الأدوار
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item">
                            <span class="nav-link text-muted">
                                🔒 يمكنك مشاهدة الروابط بعد الدخول ...
                            </span>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-globe ms-1"></i> عرض الموقع
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white fw-bold d-flex align-items-center"
                               href="#"
                               id="userDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                <i class="fas fa-user-circle ms-1"></i>
                                @User.Identity.Name
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-2" aria-labelledby="userDropdown">
                              

                                <li>
                                    <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Account" asp-action="ChangePassword">
                                        <i class="fas fa-key ms-2 text-warning"></i>
                                        تغيير كلمة المرور
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout"
                                          asp-route-returnUrl="/Identity/Account/Login"
                                          method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item py-2 text-danger">
                                            <i class="fas fa-sign-out-alt ms-2"></i>
                                            تسجيل الخروج
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-globe ms-1"></i> عرض الموقع
                            </a>
                        </li>
                    }
                </ul>
              @*   <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">عرض الموقع</a></li>
                    <li class="nav-item">
                        <form asp-area="Identity" asp-page="/Account/Logout"
                              asp-route-returnUrl="/Identity/Account/Login" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link text-danger fw-bold btn btn-link">
                                <i class="fas fa-sign-out-alt ms-1"></i> تسجيل الخروج
                            </button>
                        </form>
                    </li>
                </ul> *@
            </div>
        </div>
    </nav>

    <!-- 🔹 Page Content -->
    <main role="main" class="container mt-2">
        @RenderBody()
    </main>

    <!-- 🔹 Footer -->
    <footer class="mt-auto py-3 text-center text-white fw-bold" style="background-color:#159d82;">
        <div class="container">
            <small>© @DateTime.Now.Year - جو أوفر | جميع الحقوق محفوظة</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- ✅ Only this one line for CKEditor -->
    <script src="~/lib/ckeditor/ckeditor.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
