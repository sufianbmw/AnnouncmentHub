@model X.PagedList.IPagedList<AnnouncmentHub.Models.Category>

@using Microsoft.AspNetCore.Mvc.Rendering
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "📋 قائمة التصنيفات";

    var categoryName = Context.Request.Query["categoryName"].ToString();
    var parentId = Context.Request.Query["parentId"].ToString();
    var onlyParents = Context.Request.Query["onlyParents"].ToString();

    var parentCategories = ViewBag.ParentCategories as List<SelectListItem> ?? new List<SelectListItem>();
}



<div class="card mb-2">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <form method="get" asp-action="Index" class="row w-100">
                <div class="col-md-4">
                    <input type="text" name="categoryName" class="form-control" placeholder="🔍 بحث بالاسم..." value="@categoryName" />
                </div>

                <div class="col-md-4">
                    <select name="parentId" class="form-select">
                        <option value="-1">-- 📂 حسب التصنيف الرئيسي --</option>
                        @foreach (var parent in parentCategories)
                        {
                            @:<option value="@parent.Value" @(parent.Value == parentId ? "selected" : "")>@parent.Text</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <input type="checkbox" name="onlyParents" value="true" class="form-check-input" id="onlyParentsCheckbox" @(onlyParents == "true" ? "checked" : "") />
                    <label for="onlyParentsCheckbox" class="form-check-label ms-2 mb-0">⭐ تصنيفات رئيسية فقط</label>
                </div>

                <div class="col-12 d-flex justify-content-center gap-2 mt-3">
                    <button type="submit" class="btn btn-primary px-4">🔎 بحث</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary px-4">♻️ إعادة تعيين</a>
                </div>
            </form>

        
        </div>

        <!-- For smaller screens, show create button below form -->
        
    </div>
  
</div>
<div class="row my-2">
 <div class="col-md">
            <a asp-action="Create" class="btn btn-success">➕ إنشاء تصنيف جديد</a>
        </div>
        </div>
 
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>❌ خطأ!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✅ نجاح!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="mt-3 d-flex justify-content-center">
    @Html.PagedListPager(Model, page => Url.Action("Index", new
    {
        page,
        categoryName,
        parentId,
        onlyParents
    }), new PagedListRenderOptions
    {
        UlElementClasses = new[] { "pagination" },
        LiElementClasses = new[] { "page-item" },
        PageClasses = new[] { "page-link" }
    })
</div>
<table class="table table-bordered table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>📛 اسم التصنيف</th>
            <th>👑 تصنيف رئيسي؟</th>
            <th>📂  التصنيفات الرئيسية المرتبطة
            (الاب)
            </th>
            <th style="width: 140px;">⚙️ إجراءات</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center">🚫 لا توجد بيانات</td></tr>
        }
        else
        {
            foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.CatName</td>
                    <td>@(cat.IsParent ? "👑 نعم" : "❌ لا")</td>
                    <td>
                        @if (cat.ParentMappings != null && cat.ParentMappings.Any())
                        {
                            @string.Join(", ", cat.ParentMappings.Select(pm => pm.ParentCategory.CatName))
                        }
                        else
                        {
                            <em>— لا يوجد —</em>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-warning me-1" title="تعديل">✏️</a>
                        <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-danger" title="حذف">🗑️</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="mt-3 d-flex justify-content-center">
    @Html.PagedListPager(Model, page => Url.Action("Index", new
    {
        page,
        categoryName,
        parentId,
        onlyParents
    }), new PagedListRenderOptions
    {
        UlElementClasses = new[] { "pagination" },
        LiElementClasses = new[] { "page-item" },
        PageClasses = new[] { "page-link" }
    })
</div>
