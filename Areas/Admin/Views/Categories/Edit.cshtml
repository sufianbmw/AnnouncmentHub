@model AnnouncmentHub.ViewModels.CategoryViewModel


@{
    ViewData["Title"] = "✏️ تعديل تصنيف";
}

<div class="container my-5">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">@ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>

                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="CatName" class="form-label fs-5">📛 @Html.DisplayNameFor(m => m.CatName)</label>
                    <input asp-for="CatName" class="form-control form-control-lg" placeholder="أدخل اسم التصنيف" />
                    <span asp-validation-for="CatName" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="IsParent" class="form-check-input" type="checkbox" id="IsParentCheckbox" />
                    <label asp-for="IsParent" for="IsParentCheckbox" class="form-check-label fs-5">👑 تصنيف رئيسي</label>
                </div>

                <div id="parentCategoriesDiv" class="mb-4 border rounded p-3">
                    <label class="form-label fs-5 fw-semibold">📂 تصنيفات رئيسية مرتبطة</label>
                    <div class="row">
                        @foreach (var parent in Model.ParentCategories)
                        {
                            <div class="col-md-3 col-sm-6 border rounded p-1 mx-1 mb-1">
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="ParentCategoryIds"
                                           value="@parent.Value"
                                           id="parentCheck_@parent.Value"
                                           @(Model.ParentCategoryIds.Contains(int.Parse(parent.Value)) ? "checked" : "") />
                                    <label class="form-check-label" for="parentCheck_@parent.Value">
                                        📁 @parent.Text
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="ParentCategoryIds" class="text-danger"></span>
                </div>

                @*    <div class="form-check form-switch mb-5">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" id="IsActiveCheckbox" />
                    <label asp-for="IsActive" for="IsActiveCheckbox" class="form-check-label fs-5">✅ مفعل</label>
                </div> *@

                @await Html.PartialAsync("_IconPicker", Model.IconName ?? Model.IconName ?? "")

                <!-- خيارات الحالة -->
                <div class="card border-secondary mb-4 p-3">
                    <h6 class="mb-3 text-secondary">⚙️ إعدادات الحالة</h6>
                    <div class="d-flex flex-wrap gap-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="IsActiveCheckbox" />
                            <label class="form-check-label" for="IsActiveCheckbox">✅ تصنيف مفعل ؟</label>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="IsVIP" class="form-check-input" type="checkbox" id="IsVIPCheckbox" />
                            <label class="form-check-label" for="IsVIPCheckbox">⭐   تصنيف VIP ؟</label>
                        </div>

                    </div>
                </div>
                <hr />

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        ↩️ رجوع
                    </a>
                    <button type="submit" class="btn btn-warning btn-lg">
                        💾 حفظ التعديلات
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Render all data-lucide icons including the picker grid
            lucide.createIcons();

            const input   = document.getElementById('IconName');
            const search  = document.getElementById('iconSearch');
            const grid    = document.getElementById('iconGrid');
            const prevIcon = document.getElementById('iconPreviewIcon');
            const prevLbl  = document.getElementById('iconPreviewLabel');
            const btns     = Array.from(grid.querySelectorAll('.icon-pick-btn'));

            function selectIcon(name) {
                input.value = name;
                prevLbl.textContent = name;
                prevIcon.setAttribute('data-lucide', name);
                lucide.createIcons();
                btns.forEach(b => {
                    const on = b.dataset.icon === name;
                    b.style.borderColor = on ? '#0d9488' : '#e0ddd4';
                    b.style.background  = on ? '#e6f4f2' : '#f7f4ee';
                    const ico = b.querySelector('i, svg');
                    if (ico) ico.style.color = on ? '#0d9488' : '#555';
                });
            }

            btns.forEach(btn => btn.addEventListener('click', () => selectIcon(btn.dataset.icon)));

            search.addEventListener('input', function () {
                const q = this.value.toLowerCase();
                btns.forEach(b => b.style.display = b.dataset.icon.includes(q) ? 'flex' : 'none');
            });

            search.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const val = this.value.trim();
                    if (val) selectIcon(val);
                }
            });
        });
    </script>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 🔹 Toggle parent categories section visibility
            function toggleParentCategories() {
                const parentCheckbox = document.getElementById('IsParentCheckbox');
                const parentDiv = document.getElementById('parentCategoriesDiv');
                if (!parentCheckbox || !parentDiv) return;
                parentDiv.style.display = parentCheckbox.checked ? 'none' : 'block';
            }

            const parentCheckbox = document.getElementById('IsParentCheckbox');
            if (parentCheckbox) {
                parentCheckbox.addEventListener('change', toggleParentCategories);
                toggleParentCategories(); // Initialize on load
            }


        });
    </script>

}
