@model RoleFormViewModel


<form method="post" asp-action="Add" class="shadow-lg p-3 m-5 bg-white rounded">

    <div class="form-group">
        <input asp-for="Name" class="form-control" placeholder="الدور/الصلاحية" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="DisplayName" class="form-control" placeholder="وصف الصلاحية" />
        <span asp-validation-for="DisplayName" class="text-danger"></span>
    </div>
    <div class="form-group text-center">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i>
           
            اضافة الصلاحية
        </button>
    </div>
</form>
