@model RoleFormViewModel

<form method="post" asp-action="Add" class="shadow-lg border-0 rounded-4 p-4">

    <!-- Header -->
    <div class="text-center mb-2">
        <h4 class="fw-bold text-primary">➕ إضافة صلاحية جديدة</h4>
    </div>

    <!-- Role Name -->
    <div class="form-floating mb-3">
        <input asp-for="Name" class="form-control rounded-3" placeholder="الدور/الصلاحية" />
        <label asp-for="Name">🛡️ اسم الدور / الصلاحية</label>
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <!-- Display Name -->
    <div class="form-floating mb-4">
        <input asp-for="DisplayName" class="form-control rounded-3" placeholder="وصف الصلاحية" />
        <label asp-for="DisplayName">📝 وصف الصلاحية</label>
        <span asp-validation-for="DisplayName" class="text-danger small"></span>
    </div>

    <!-- Submit -->
    <div class="d-grid">
        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">
            💾 حفظ الصلاحية
        </button>
    </div>

</form>
