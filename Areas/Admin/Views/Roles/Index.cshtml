@model IEnumerable<ApplicationRole>
@{
    ViewData["Title"] = "أدارة الادوار/الصلاحيات";
}
<h3 class="m-4">
    أدارة الادوار/الصلاحيات
</h3>
<hr />
<partial name="_RoleForm" model="new RoleFormViewModel()" />
<hr />
@*<div id="partialZone"></div>*@
<table class="table table-striped mt-5">
    <thead>
        <tr class="bg-primary text-white">
            @*<th>معرف</th>*@
            <th>الدور /الصلاحية</th>
            <th>وصف الصلاحية</th>
            <th class="text-center">العمليات</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                @*<td>@role.Id </td>*@
                <td>@role.Name </td>
                <td>@role.DisplayName </td>
                <td class="text-center">
                    <a class="btn btn-primary" asp-controller="Roles" asp-action="Edit" asp-route-roleId="@role.Id">
                        <i class="fas fa-edit"></i>
                        تعديل الصلاحية
                    </a>
                    <a class="btn btn-danger" asp-controller="Roles" asp-action="Delete" asp-route-roleId="@role.Id">
                        <i class="fas fa-trash"></i>
                        حذف الصلاحية
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
@section Scripts {
@*<script>
    $('#partialZone').load('/Roles/GetRole');

</script>
    <partial name="_ValidationScriptsPartial" />
}*@
}