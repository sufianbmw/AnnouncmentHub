@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "غير مصرح بالدخول";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center p-5 rounded-4 shadow-lg border border-danger border-opacity-25"
         style="max-width: 550px; background: linear-gradient(135deg, #fff5f5, #fff);">

        <div class="mb-4">
            <span style="font-size: 6rem;">🚫</span>
        </div>

        <div class="mb-2">
            <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill">
                ⚠️ خطأ 403
            </span>
        </div>

        <h1 class="fw-bold text-danger mt-3 mb-2" style="font-size: 2rem;">
            🔒 @ViewData["Title"]
        </h1>

        <p class="text-muted fs-5 mb-4">
            عذراً! لا تملك الصلاحية للوصول إلى هذه الصفحة. <br />
            يرجى التواصل مع المدير إذا كنت تعتقد أن هذا خطأ. 🙏
        </p>

        <hr class="text-danger opacity-25" />

        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <a href="javascript:history.back()"
               class="btn btn-outline-danger btn-lg rounded-pill px-4">
                ⬅️ العودة للخلف
            </a>
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="btn btn-danger btn-lg rounded-pill px-4 text-white">
                🏠 الصفحة الرئيسية
            </a>
        </div>

        <div class="mt-4 p-3 rounded-3 bg-danger bg-opacity-10">
            <small class="text-danger">
                🛡️ إذا كنت تعتقد أن هذا خطأ، تواصل مع
                <a href="mailto:admin@example.com" class="text-danger fw-bold">
                    المدير
                </a>
            </small>
        </div>

    </div>
</div>