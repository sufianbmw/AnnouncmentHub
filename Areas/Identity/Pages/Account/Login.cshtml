@page
@model LoginModel
@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient text-white text-center" style="background: linear-gradient(45deg, #007bff, #0056b3);">
                    <h4 class="mb-0">🔐 تسجيل الدخول</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="input-group mb-3">
                            <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                            <input asp-for="Input.Email" class="form-control" placeholder="أدخل بريدك الإلكتروني" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>

                        <div class="input-group mb-3">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Input.Password" class="form-control" placeholder="أدخل كلمة المرور" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>

                        <div class="form-check mb-3">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">تسجيل الدخول</button>
                    </form>
                </div>
                <div class="card-footer text-center bg-light">
                    <a asp-page="./ForgotPassword" class="text-decoration-none me-2">نسيت كلمة المرور؟</a>
                    <a asp-page="./Register" class="text-decoration-none me-2">إنشاء حساب جديد</a>
                    <a asp-page="./ResendEmailConfirmation" class="text-decoration-none">إعادة إرسال تأكيد البريد</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
